  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Favorites (wishlist + sale notifications) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model Favorite {
  userId    String
  gameId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // One row per (user, game). Toggle by upsert/delete.
  @@id([userId, gameId])
  @@index([gameId])
  @@index([userId, createdAt])
}

// Dedup table ‚ÄĒ one row per sale-notification email sent.
// Keyed by (userId, gameId, discountStartedAt) where discountStartedAt is the
// timestamp at which the favorited game first transitioned from no-discount to
// discount during a scrape run. Prevents re-sending if a later scrape run sees
// the same active sale window.
model FavoriteNotification {
  id                String   @id @default(cuid())
  userId            String
  gameId            String
  // Snapshot of the discount start date so a future *new* sale (separate from
  // the one we already notified for) creates a fresh row.
  discountStartedAt DateTime
  sentAt            DateTime @default(now())

  @@unique([userId, gameId, discountStartedAt])
  @@index([gameId])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ FAQ (homepage "Tez-tez veril…ôn suallar") ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  /// FAQ-ńĪn g√∂st…ôril…ôc…ôyi s…ôhif…ô: HOME | PLAYSTATION | STREAMING_OVERVIEW |
  /// STREAMING_HBO_MAX | STREAMING_GAIN | STREAMING_NETFLIX | STREAMING_YOUTUBE
  scope     String   @default("HOME")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, isActive, sortOrder])
}

/// Platforma b…ôl…ôd√ßil…ôri ‚ÄĒ "FaydalńĪ baŇülńĪqlar" sah…ôl…ôrind…ô g√∂st…ôril…ôn qńĪsa
/// guide-lar (m…ôs: "HBO Max-ńĪ nec…ô y√ľkl…ôm…ôk olar"). H…ôr guide bir scope-a
/// bańülanńĪr v…ô m√ľvafiq s…ôhif…ôd…ô g√∂r√ľn√ľr.
model PlatformGuide {
  id        String   @id @default(cuid())
  /// Public path-larda istifad…ô √ľ√ß√ľn unikal slug.
  slug      String   @unique
  title     String
  /// QńĪsa t…ôsvir ‚ÄĒ kart preview-da g√∂st…ôrilir.
  summary   String?
  /// Tam m…ôtn ‚ÄĒ markdown yox, plain text saxlanńĪlńĪr (x…ôtt sonu pre-line il…ô render).
  body      String
  /// Opsional YouTube video linki ‚ÄĒ varsa, kartda &laquo;Videoya bax&raquo; d√ľym…ôsi
  /// g√∂st…ôrilir v…ô klikd…ô yeni tab-da a√ßńĪlńĪr.
  videoUrl  String?
  /// Scope: HOME | PLAYSTATION | STREAMING_HBO_MAX | STREAMING_GAIN | v…ô s.
  scope     String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, isActive, sortOrder])
}

/// X…ôb…ôrl…ôr ‚ÄĒ admin paneld…ôn idar…ô olunan platforma-spesifik x…ôb…ôr/elan/yenilik
/// kartlarńĪ. H…ôr x…ôb…ôr bir scope-a bańülanńĪr (HOME | PLAYSTATION | STREAMING_*),
/// PlayStation, Streaming v…ô Music s…ôhif…ôl…ôrind…ô uyńüun scope-lu x…ôb…ôrl…ôr
/// g√∂st…ôrilir. `isFeatured` true olduqda kart b√∂y√ľk "hero" formatńĪnda render
/// olunur.
model NewsArticle {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  /// QńĪsa anons m…ôtni ‚ÄĒ kartlarda g√∂st…ôrilir.
  excerpt       String?
  /// Tam m…ôtn ‚ÄĒ `whitespace-pre-line` il…ô render olunur.
  body          String
  /// Cover Ňü…ôkil URL-i (Cloudinary v…ô ya h…ôr hansńĪ CDN).
  coverImageUrl String?
  /// Optional kategori etiketi: "Yenilik", "Endirim", "M√ľsahib…ô", "B…ôl…ôd√ßi" v…ô s.
  category      String?
  /// Scope: HOME | PLAYSTATION | STREAMING_OVERVIEW | STREAMING_HBO_MAX | STREAMING_NETFLIX | STREAMING_GAIN | STREAMING_YOUTUBE_PREMIUM
  scope         String    @default("HOME")
  isFeatured    Boolean   @default(false)
  isPublished   Boolean   @default(true)
  /// Ana s…ôhif…ôd…ô d…ô g√∂st…ôrilirmi ‚ÄĒ admin paneld…ôn manual se√ßilir.
  showOnHome    Boolean   @default(false)
  /// Public render √ľ√ß√ľn effective tarix ‚ÄĒ null olarsa createdAt istifad…ô edilir.
  publishedAt   DateTime?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([scope, isPublished, publishedAt])
  @@index([scope, isFeatured, sortOrder])
  @@index([showOnHome, isPublished, publishedAt])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Referral cycles (aylńĪq leaderboard tracking) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
//
// H…ôr t…ôqvim ayńĪ bir `ReferralCycle` t…ôŇükil edir. Cycle daxilind…ô h…ôr referrer
// √ľ√ß√ľn `ReferralCycleResult` s…ôtri xal yńĪńüńĪr:
//   - h…ôr "uńüurlu d…ôv…ôt" √ľ√ß√ľn +10 xal (referee-nin ilk SUCCESS alńĪŇüńĪ)
//   - referee-nin x…ôrcl…ôdiyi h…ôr AZN √ľ√ß√ľn +1 xal
// Bonus referal komissiyasńĪ kimi m…ôbl…ôńü…ô …ôsas…ôn verilir (pill…ô sistemi yoxdur).

model ReferralCycle {
  id        String    @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  closedAt  DateTime?
  createdAt DateTime  @default(now())

  results ReferralCycleResult[]

  @@unique([startsAt])
  @@index([endsAt])
}

model ReferralCycleResult {
  id      String        @id @default(cuid())
  cycleId String
  cycle   ReferralCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  userId  String
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  invites    Int @default(0)
  spendCents Int @default(0)
  points     Int @default(0)

  rank Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cycleId, userId])
  @@index([cycleId, points])
  @@index([userId])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Game reviews (r…ôyl…ôr) + sosial qarŇüńĪlńĪqlńĪ t…ôsir + affiliate ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
//
// H…ôr istifad…ô√ßi bir oyun √ľ√ß√ľn yalnńĪz bir r…ôy yaza bil…ôr. R…ôy admin
// moderasiyasńĪndan ke√ßdikd…ôn sonra (status = APPROVED) public g√∂r√ľn√ľr.
// R…ôy kartńĪndakńĪ "Bu Oyunu SatńĪn Al" d√ľym…ôsin…ô klikl…ôy…ôn h…ôr k…ôs
// `?via=<reviewId>` query parametri il…ô oyun s…ôhif…ôsin…ô y√∂nl…ôndirilir;
// bu identifikator 30 g√ľnl√ľk HTTP-only cookie-y…ô yazńĪlńĪr v…ô alńĪŇü SUCCESS
// status alanda r…ôy m√ľ…ôllifin…ô referal balansńĪndan komissiya yazńĪlńĪr.

model GameReview {
  id     String @id @default(cuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 1..5 (UI-da ulduz). Server t…ôr…ôfd…ô d…ô limitl…ônir.
  rating Int
  // 200..5000 simvol. H…ôr iki t…ôr…ôfd…ô validasiya olunur.
  body   String

  // PENDING | APPROVED | REJECTED | HIDDEN
  // PENDING  ‚ÄĒ yeni g√∂nd…ôrilmiŇü, admin onayńĪnńĪ g√∂zl…ôyir
  // APPROVED ‚ÄĒ public g√∂r√ľn√ľr
  // REJECTED ‚ÄĒ admin r…ôdd edib (g√∂r√ľnm…ôz)
  // HIDDEN   ‚ÄĒ adminin …ôvv…ôl onayladńĪńüńĪ, sonra gizl…ôdiyi r…ôy
  status String @default("PENDING")

  // Admin moderasiya audit-i.
  moderatedAt    DateTime?
  moderatedById  String?
  moderationNote String?

  reactions ReviewReaction[]
  comments  ReviewComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // H…ôr istifad…ô√ßi bir oyun √ľ√ß√ľn bir r…ôy.
  @@unique([userId, gameId])
  @@index([gameId, status, createdAt])
  @@index([userId])
  @@index([status])
}

model ReviewReaction {
  reviewId String
  review   GameReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // +1 (Like) | -1 (Dislike). Toggle: eyni d…ôy…ôr t…ôkrar g…ôls…ô kayńĪt silinir,
  // …ôks d…ôy…ôr g…ôls…ô is…ô update olunur.
  value Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([reviewId, userId])
  @@index([reviewId, value])
}

model ReviewComment {
  id       String     @id @default(cuid())
  reviewId String
  review   GameReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  body     String
  // Admin t…ôr…ôfind…ôn gizl…ônilibs…ô, public siyahńĪda g√∂r√ľnm√ľr.
  isHidden Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId, createdAt])
  @@index([userId])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Streaming Scraper: √ßoklu platform katalog/dil bilgisi ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

/// Bir StreamingTitle-ńĪn konkret platformdakńĪ m√∂vcudluńüu. Eyni baŇülńĪq bird…ôn
/// √ßox platformda yayńĪmlana bil…ôr (m…ôs. eyni film h…ôm Netflix, h…ôm Prime-da).
/// Scraper h…ôr run-da bu c…ôdv…ôli AZ kataloqu il…ô sinxronlaŇüdńĪrńĪr.
model ContentAvailability {
  id                 String         @id @default(cuid())
  titleId            String
  title              StreamingTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)
  // NETFLIX | HBOMAX | PRIME | GAIN
  platform           String
  // Platform daxilind…ôki ID/slug ‚ÄĒ deep link qurmaq √ľ√ß√ľn (m…ôs. Netflix netflix_id,
  // JustWatch jw_entity_id, Gain √ľ√ß√ľn URL slug-ńĪ).
  platformExternalId String
  // Region ‚ÄĒ hazńĪrda h…ôr zaman "AZ", lakin g…ôl…ôc…ôkd…ô multi-region √ľ√ß√ľn saxlanńĪr.
  country            String         @default("AZ")
  // Sonuncu scrape-d…ô platformda g√∂r√ľn√ľbs…ô true. Silindikd…ô false + removedAt set olunur.
  isAvailable        Boolean        @default(true)
  firstSeenAt        DateTime       @default(now())
  lastSeenAt         DateTime       @default(now())
  removedAt          DateTime?
  // Platform t…ôr…ôfind…ôki deep link (m…ôs. https://www.netflix.com/az/title/80100172).
  deepLinkUrl        String?

  languages ContentLanguage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, platformExternalId, country])
  @@index([titleId])
  @@index([platform, isAvailable])
}

/// Bir availability √ľ√ß√ľn audio/subtitle dil siyahńĪsńĪ. YalnńĪz tr/ru/en saxlanńĪr ‚ÄĒ
/// dig…ôr dill…ôr scraper-d…ô s√ľz√ľl√ľr (bax `lib/streamingLanguages.ts`).
model ContentLanguage {
  id             String              @id @default(cuid())
  availabilityId String
  availability   ContentAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  // ISO 639-1: "tr" | "ru" | "en"
  code           String
  // AUDIO | SUBTITLE
  kind           String

  createdAt DateTime @default(now())

  @@unique([availabilityId, code, kind])
  @@index([availabilityId])
}

/// Bir scrape run-ńĪnda qeyd olunan d…ôyiŇüiklik (yeni / silinmiŇü / yenil…ônmiŇü).
/// Audit/diff √ľ√ß√ľn ‚ÄĒ UI-da "son 24 saatda n…ô d…ôyiŇüib" g√∂st…ôrm…ôk √ľ√ß√ľn istifad…ô olunur.
model ScrapeChange {
  id          String    @id @default(cuid())
  scrapeRunId String
  scrapeRun   ScrapeRun @relation(fields: [scrapeRunId], references: [id], onDelete: Cascade)
  // NETFLIX | HBOMAX | PRIME | GAIN
  platform    String
  // ADDED | REMOVED | UPDATED
  changeType  String
  // H…ôl…ô DB-d…ô olmayan REMOVED case √ľ√ß√ľn titleId null ola bil…ôr.
  titleId     String?
  // Snapshot ‚ÄĒ baŇülńĪq, platformExternalId v…ô d…ôyiŇü…ôn sah…ôl…ôr (yeni/k√∂hn…ô audio/subtitle dill…ôri).
  payload     Json

  createdAt DateTime @default(now())

  @@index([scrapeRunId])
  @@index([platform, createdAt])
  @@index([titleId])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Rate limiting / abuse defence ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
//
// H…ôr auth-y√∂nl√ľ c…ôhd (register, resend-otp, forgot-password) burada qeyd
// olunur. S√ľr√ľŇü…ôn p…ônc…ôr…ô (sliding window) il…ô son N saniy…ôd…ôki s…ôtirl…ôr
// sayńĪlaraq limit yoxlanńĪlńĪr. `identifier` ikinci √∂l√ß√ľ √ľ√ß√ľnd√ľr ‚ÄĒ m…ôs: eyni
// IP-d…ôn g…ôl…ôn 5 d…ôq …ôrzind…ôki f…ôrqli telefon n√∂mr…ôl…ôrinin sayńĪnńĪ saymaq.
model RateLimitEvent {
  id         String   @id @default(cuid())
  key        String // m…ôs: "register:ip:1.2.3.4" v…ô ya "verify-otp:user:abc"
  scope      String // "register" | "resend-otp" | "forgot-password" | "verify-otp"
  identifier String? // optional ikinci d…ôy…ôr (phone, email) distinct-count √ľ√ß√ľn
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([key, createdAt])
  @@index([scope, createdAt])
}
