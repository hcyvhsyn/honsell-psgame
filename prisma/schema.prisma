// Honsell PS Store ‚ÄĒ Prisma schema
// Provider: PostgreSQL (Supabase).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Auth / Users ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  phone        String?
  passwordHash String
  role         String  @default("USER") // USER | ADMIN

  // Optional profile fields edited from /profile/settings.
  birthDate DateTime?
  gender    String? // "MALE" | "FEMALE" | "OTHER"
  /// Avatar Ňü…ôkil URL-i ‚ÄĒ icmallar v…ô profil sah…ôl…ôrind…ô g√∂st…ôrilir.
  /// BoŇü olarsa client t…ôr…ôfd…ô h…ôrfli avatar (initial badge) √ß…ôkilir.
  avatarUrl String?

  emailVerified Boolean   @default(false)
  otpCode       String?
  otpExpiresAt  DateTime?
  // Brute-force qorumasńĪ: s…ôhv OTP giriŇül…ôri sayńĪlńĪr, m√ľ…ôyy…ôn h…ôdd…ôn sonra
  // otpLockedUntil tarixin…ô q…ôd…ôr verify-otp endpoint-i 429 qaytarńĪr.
  otpAttempts   Int       @default(0)
  otpLockedUntil DateTime?

  // Set when an admin manually creates the account. The user receives an email
  // with a one-time link ‚Üí /set-password?token=‚Ä¶ that lets them choose a
  // password and verifies their email in one step.
  setPasswordToken          String?   @unique
  setPasswordTokenExpiresAt DateTime?

  // Wallet (stored in AZN, scaled by 100 to keep integer math clean)
  walletBalance Int @default(0) // depozit / √∂d…ôniŇü √ľ√ß√ľn …ôsas c√ľzdan

  /**
   * Loyalty cashback bu balansa yńĪńüńĪlńĪr (c√ľzdandan ayrńĪ).
   */
  cashbackBalanceCents Int @default(0)

  /**
   * Referaldan komissiya il…ô d√ľŇü…ôn balans ‚ÄĒ √∂d…ôniŇüd…ô ayrńĪca se√ßilir.
   */
  referralBalanceCents Int @default(0)

  // Affiliate / referral
  referralCode String  @unique
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referrals")

  // PSN delivery accounts (one user can have many; one is marked default).
  psnAccounts PsnAccount[]

  transactions Transaction[] @relation("UserTransactions")
  commissions  Transaction[] @relation("CommissionBeneficiary")

  subscriptions Subscription[]

  favorites Favorite[]

  referralCycleResults ReferralCycleResult[]

  gameReviews     GameReview[]
  reviewReactions ReviewReaction[]
  reviewComments  ReviewComment[]

  // Streaming icmal sistemi ‚ÄĒ etibarlńĪ istifad…ô√ßil…ôrin yazdńĪńüńĪ icmallar admin
  // moderasiyasńĪ olmadan d…ôrhal APPROVED kimi yayńĪmlanńĪr.
  streamingReviewTrusted   Boolean                   @default(false)
  streamingReviews         StreamingReview[]
  streamingReviewReactions StreamingReviewReaction[]
  streamingTitleFavorites  StreamingTitleFavorite[]

  // Honsell h…ôdiyy…ô kartlarńĪ ‚ÄĒ istifad…ô√ßinin aldńĪńüńĪ v…ô aktivl…ôŇüdirdiyi kartlar.
  honsellGiftCardsPurchased HonsellGiftCard[] @relation("HonsellGiftCardPurchases")
  honsellGiftCardsRedeemed  HonsellGiftCard[] @relation("HonsellGiftCardRedemptions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ‚ĒÄ‚ĒÄ‚ĒÄ PSN delivery accounts (one user ‚Üí many PSN logins) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model PsnAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Friendly nickname shown in dropdowns ("Main", "Brother", "Eu Region")
  label       String
  psnEmail    String
  psnPassword String // encrypt at rest in production

  /// Console model the account is bound to. "PS4" | "PS5".
  psModel String @default("PS5")

  isDefault Boolean @default(false)

  transactions  Transaction[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Catalog ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model Game {
  id         String  @id @default(cuid())
  // Stable PS Store product id (used to upsert during scraping)
  productId  String  @unique
  title      String
  imageUrl   String?
  productUrl String?

  // PS4 | PS5 ‚ÄĒ derived from the productId code (CUSA/PPSA)
  platform String?

  // GAME | ADDON | CURRENCY | OTHER ‚ÄĒ derived from storeDisplayClassification
  // GAME      ‚Üí FULL_GAME, GAME_BUNDLE, PREMIUM_EDITION, null (concept page)
  // ADDON     ‚Üí ADD_ON_PACK (DLC, costumes, season passes)
  // CURRENCY  ‚Üí VIRTUAL_CURRENCY (cash cards)
  // OTHER     ‚Üí themes, avatars, demos, anything else
  productType String @default("GAME")

  // Source prices in TRY, scaled by 100 (kuruŇü). Never shown to users.
  priceTryCents    Int
  discountTryCents Int? // null when no discount is active
  discountEndAt    DateTime? // when the active discount expires (from PS Store)

  // Rich media + metadata scraped from PS Store listing pages
  heroImageUrl String? // BACKGROUND-role media (wide hero/cover)
  trailerUrl   String? // PREVIEW-role media (mp4 trailer URL)
  screenshots  Json? // String[] ‚ÄĒ additional IMAGE-role media URLs
  editionLabel String? // e.g. "Tam S√ľr√ľm Oyun", "Premium S√ľr√ľm"

  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  lastScrapedAt DateTime @default(now())

  transactions Transaction[]
  banners      Banner[]
  collections  CollectionGame[]
  favorites    Favorite[]
  reviews      GameReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platform])
  @@index([productType])
  @@index([title])
  @@index([isFeatured])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Collections (curated game lists) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model Collection {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  games CollectionGame[]

  @@index([isActive, sortOrder])
  @@index([isFeatured])
}

model CollectionGame {
  collectionId String
  gameId       String
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  game       Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([collectionId, gameId])
  @@index([collectionId, position])
  @@index([gameId])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Service Products (TRY Balans, PS Plus, Account Creation) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model ServiceProduct {
  id            String  @id @default(cuid())
  // ACCOUNT_CREATION | TRY_BALANCE | PS_PLUS
  type          String
  title         String
  description   String?
  imageUrl      String?
  // Qiym…ôt (AZN q…ôpikl…ô)
  priceAznCents Int

  // ∆Źlav…ô m…ôlumatlar:
  // TRY_BALANCE √ľ√ß√ľn: ne√ß…ô TRY-dir (m…ôs: 250, 500)
  // PS_PLUS √ľ√ß√ľn: tier (ESSENTIAL/EXTRA/DELUXE) v…ô durationMonths (1, 3, 12)
  metadata Json?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  codes         ServiceCode[]
  transactions  Transaction[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model ServiceCode {
  id               String         @id @default(cuid())
  serviceProductId String
  serviceProduct   ServiceProduct @relation(fields: [serviceProductId], references: [id])

  code   String // 12 r…ôq…ômli e-pin v…ô s.
  isUsed Boolean @default(false)

  transactions Transaction[]

  createdAt DateTime @default(now())

  @@index([serviceProductId, isUsed])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Honsell Gift Cards (√∂z markamńĪzńĪn h…ôdiyy…ô kartlarńĪ) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
//
// M√ľŇüt…ôri 5/10/20/50/100/200/500/1000 AZN nominalńĪnda kart alńĪr, sistem 11
// simvollu unikal kod generasiya edir v…ô alńĪcńĪya email il…ô g√∂nd…ôrilir.
// ńįst…ônil…ôn baŇüqa istifad…ô√ßi h…ômin kodu "/profile/hediyye-kart" s…ôhif…ôsind…ô
// daxil ed…ôr…ôk c√ľzdan balansńĪna m…ôbl…ôńüi k√∂√ß√ľr…ô bil…ôr. Kodlar 1 il etibarlńĪdńĪr.

model HonsellGiftCard {
  id             String @id @default(cuid())
  // 11 simvollu unikal kod ‚ÄĒ alńĪcńĪya verilir, aktivl…ôŇüdirm…ô √ľ√ß√ľn lazńĪmdńĪr.
  code           String @unique
  // KartńĪn AZN q…ôpikl…ô nominalńĪ (5 AZN ‚Üí 500).
  amountAznCents Int
  // ACTIVE | REDEEMED ‚ÄĒ bir kart yalnńĪz bir d…ôf…ô istifad…ô oluna bil…ôr.
  status         String @default("ACTIVE")

  // AlńĪcńĪ (system-d…ô qeydiyyatlńĪ istifad…ô√ßi olmalńĪdńĪr).
  purchasedById         String?
  purchasedBy           User?    @relation("HonsellGiftCardPurchases", fields: [purchasedById], references: [id])
  // AlńĪŇü √ľ√ß√ľn yaradńĪlmńĪŇü SERVICE_PURCHASE tranzaksiyasńĪnńĪn id-si (audit).
  purchaseTransactionId String?
  purchasedAt           DateTime @default(now())

  // Aktivl…ôŇüdir…ôn istifad…ô√ßi (√∂z√ľ ola bil…ôr, baŇüqasńĪ da). NULL qaldńĪqca ACTIVE.
  redeemedById        String?
  redeemedBy          User?     @relation("HonsellGiftCardRedemptions", fields: [redeemedById], references: [id])
  redeemTransactionId String?
  redeemedAt          DateTime?

  // Bitm…ô tarixi ‚ÄĒ alńĪŇüdan 1 il sonra. Bu tarixd…ôn sonra aktivl…ôŇüdirm…ô bloklanńĪr.
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([purchasedById])
  @@index([redeemedById])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Transactions (deposits, purchases, commissions) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model Transaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserTransactions", fields: [userId], references: [id])

  // DEPOSIT | PURCHASE | COMMISSION | SERVICE_PURCHASE
  type   String
  // PENDING | SUCCESS | FAILED
  status String @default("SUCCESS")

  // Amount in q…ôpik (AZN * 100). Positive = credit, negative = debit.
  amountAznCents Int

  // Customer savings on this transaction (AZN q…ôpik, ‚Č• 0). Set on PURCHASE
  // rows when a discount was active at checkout: original ‚ąí final per unit √ó
  // qty. Profile aggregates this to display lifetime savings.
  savingsAznCents Int @default(0)

  // Optional purchase details
  gameId String?
  game   Game?   @relation(fields: [gameId], references: [id])

  serviceProductId String?
  serviceProduct   ServiceProduct? @relation(fields: [serviceProductId], references: [id])

  serviceCodeId String?
  serviceCode   ServiceCode? @relation(fields: [serviceCodeId], references: [id])

  // Which PSN account this purchase was delivered to. NULL for non-PURCHASE
  // rows (DEPOSIT, COMMISSION) and for legacy data created before multi-PSN.
  psnAccountId String?
  psnAccount   PsnAccount? @relation(fields: [psnAccountId], references: [id])

  // For COMMISSION rows: the user who earned the commission
  beneficiaryId String?
  beneficiary   User?   @relation("CommissionBeneficiary", fields: [beneficiaryId], references: [id])

  // Free-form metadata (e.g. masked card, gateway ref)
  metadata String?

  // Manual-deposit receipt URL (uploaded by the customer, reviewed by admin)
  receiptUrl String?

  createdAt DateTime @default(now())

  @@index([status, type])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ PS Plus subscriptions (auto-renew, expiry tracking) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model Subscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceProductId String
  serviceProduct   ServiceProduct @relation(fields: [serviceProductId], references: [id])

  // Optional PSN account this subscription is bound to (nullable for legacy/unbound).
  psnAccountId String?
  psnAccount   PsnAccount? @relation(fields: [psnAccountId], references: [id])

  // Snapshot fields so the row stays meaningful even if the ServiceProduct row changes.
  tier           String // ESSENTIAL | EXTRA | DELUXE
  durationMonths Int // 1 | 3 | 12 ‚ÄĒ used as the auto-renew period.
  priceAznCents  Int // Last-known renewal price in q…ôpik.

  startsAt  DateTime
  expiresAt DateTime

  // ACTIVE | CANCELLED | EXPIRED
  status String @default("ACTIVE")

  autoRenew Boolean @default(false)

  // Notification de-dup. Stores the expiry-date these reminders were sent for,
  // so a subscription that gets renewed gets a fresh reminder cycle.
  remind3SentAt    DateTime?
  remind1SentAt    DateTime?
  lowBalanceSentAt DateTime?

  // Last successful renewal info (admin debugging).
  lastRenewedAt   DateTime?
  lastRenewalTxId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, expiresAt])
  @@index([autoRenew, expiresAt])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ PS Store scrape history ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model ScrapeRun {
  id            String    @id @default(cuid())
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  // RUNNING | SUCCESS | PARTIAL | FAILED
  status        String    @default("RUNNING")
  // PS_STORE | STREAMING ‚ÄĒ ayńĪrt etmek √ľ√ß√ľn, eyni c…ôdv…ôld…ô h…ôr iki n√∂v run saxlanńĪr.
  kind          String    @default("PS_STORE")
  // Total unique products extracted from PS Store before persisting.
  scrapedCount  Int       @default(0)
  // Rows actually upserted into Game (== scrapedCount on success).
  upsertedCount Int       @default(0)
  // Streaming run-larda platform breakdown ‚ÄĒ JSON: { netflix: { added, removed, updated, errors }, ... }
  summary       Json?
  error         String?

  changes ScrapeChange[]

  @@index([startedAt])
  @@index([kind, startedAt])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Banners (homepage hero carousel) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model Banner {
  id             String   @id @default(cuid())
  title          String?
  subtitle       String?
  imageUrl       String
  // Mobil cihazlar √ľ√ß√ľn opsional alternativ Ňü…ôkil. BoŇü olduqda `imageUrl` istifad…ô olunur.
  mobileImageUrl String?
  linkUrl        String?
  // LINK | ADD_TO_CART
  actionType     String   @default("LINK")
  gameId         String?
  game           Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  /// Bannerin g√∂st…ôril…ôc…ôyi s…ôhif…ô: HOME | PLAYSTATION | (g…ôl…ôc…ôkd…ô yeni scope-lar
  /// …ôlav…ô oluna bil…ôr). H…ôr scope-un √∂z sńĪralamasńĪ v…ô idar…ôsi var.
  scope          String   @default("HOME")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([gameId])
  @@index([scope, isActive, sortOrder])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Streaming Content (films & series available on streaming services) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

/// Bir film v…ô ya seriya. Streaming xidm…ôtinin (HBO Max, Gain, YouTube Premium,
/// Netflix) Az…ôrbaycanda yayńĪmlanan kataloqunu admin manual olaraq saxlayńĪr.
/// `azAvailable=false` olan title-lar public-d…ô gizl…ônir.
model StreamingTitle {
  id                String  @id @default(cuid())
  // Public path-larda istifad…ô olunan unikal slug (m…ôs: "stranger-things").
  slug              String  @unique
  title             String
  // MOVIE | SERIES
  kind              String  @default("MOVIE")
  // STREAMING_SERVICES-d…ôn biri: HBO_MAX | GAIN | YOUTUBE_PREMIUM | NETFLIX
  service           String
  posterUrl         String?
  backdropUrl       String?
  year              Int?
  // String massivi JSON kimi: ["Drama", "Sci-Fi"]
  genres            Json?
  description       String?
  // Az…ôrbaycanda yayńĪmlanńĪr? Public listing-d…ô yalnńĪz true olanlar g√∂st…ôrilir.
  azAvailable       Boolean @default(true)
  isActive          Boolean @default(true)
  sortOrder         Int     @default(0)
  // Xarici provayder ID-si (OMDb halńĪnda IMDb ID, m…ôs: "tt0372784"). Avtomatik
  // doldurulduqda dublikatńĪn qarŇüńĪsńĪnńĪ almaq √ľ√ß√ľn istifad…ô olunur.
  externalId        String?
  // OMDb-d…ôn √ß…ôkil…ôn orijinal dil kodu (m…ôs: "en", "tr", "ru").
  originalLanguage  String?
  // Admin manual se√ßir ‚ÄĒ ISO dil kodlarńĪ massivi: ["az", "tr", "en"]
  dubbedLanguages   Json?
  subtitleLanguages Json?
  // YouTube trailer linki (m…ôs: "https://www.youtube.com/watch?v=abc123").
  // TMDB-d…ôn orijinal dild…ô r…ôsmi trailer √ľst√ľn, manual override m√ľmk√ľnd√ľr.
  trailerUrl        String?

  featured       StreamingFeatured[]
  availabilities ContentAvailability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([service, isActive, azAvailable])
  @@index([service, sortOrder])
  @@index([externalId])
}

/// Streaming overview v…ô ya konkret service s…ôhif…ôsind…ô g√∂st…ôril…ôn banner
/// elementi. Admin h…ôr scope √ľ√ß√ľn ayrńĪca banner siyahńĪsńĪ qurur.
model StreamingFeatured {
  id        String         @id @default(cuid())
  // "OVERVIEW" v…ô ya konkret service kodu (HBO_MAX, GAIN, YOUTUBE_PREMIUM, NETFLIX)
  scope     String
  titleId   String
  title     StreamingTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)
  isActive  Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([scope, isActive, sortOrder])
  @@index([titleId])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Streaming customer reviews ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

/// M√ľŇüt…ôrinin TMDB film/serial √ľzr…ô yazdńĪńüńĪ icmal. tmdbId+kind referansdńĪr;
/// admin StreamingTitle-dan asńĪlńĪ deyil. Snapshot sah…ôl…ôri TMDB datasńĪnńĪ saxlayńĪr
/// ki, icmal g√∂st…ôrm…ôk √ľ√ß√ľn h…ôr d…ôf…ô TMDB-y…ô m√ľraci…ôt etm…ôy…ôk.
model StreamingReview {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// TMDB id (movie/tv) ‚ÄĒ bizim StreamingTitle row-dan asńĪlńĪ olmadan icmal yazńĪlńĪr.
  tmdbId  Int
  /// MOVIE | SERIES ‚ÄĒ TMDB endpoint se√ßimi √ľ√ß√ľn lazńĪmdńĪr.
  kind    String
  /// M√ľŇüt…ôrinin baxdńĪńüńĪ platforma: HBO_MAX | GAIN | YOUTUBE_PREMIUM | NETFLIX
  service String

  /// 1‚Äď10
  rating        Int
  /// ńįcmal m…ôtni (c…ôza-filterd…ôn ke√ßir).
  body          String
  /// ńįzl…ôm…ô dili ‚ÄĒ tr | ru | en | original
  watchLanguage String?
  /// ńįcmalda spoiler varmńĪ? Spoiler-li icmallar baŇüqalarńĪ √ľ√ß√ľn blur il…ô g√∂st…ôrilir,
  /// klik etdikd…ô a√ßńĪlńĪr.
  spoiler       Boolean @default(false)

  /// PENDING | APPROVED | REJECTED
  status         String  @default("PENDING")
  rejectedReason String?

  // Snapshot ‚ÄĒ icmali g√∂st…ôrm…ôk √ľ√ß√ľn TMDB-d…ôn kopyalanńĪr
  titleSnap       String
  posterUrlSnap   String?
  backdropUrlSnap String?
  yearSnap        Int?
  genresSnap      Json?

  reactions StreamingReviewReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Eyni istifad…ô√ßi eyni filmi / serialńĪ yalnńĪz bir d…ôf…ô icmal ed…ô bilir.
  @@unique([userId, tmdbId, kind])
  @@index([status, createdAt])
  @@index([tmdbId, kind, status])
  @@index([service, status])
}

model StreamingReviewReaction {
  id        String          @id @default(cuid())
  reviewId  String
  review    StreamingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// LIKE | DISLIKE
  kind      String
  createdAt DateTime        @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

/// M√ľŇüt…ôrinin TMDB film/serial √ľ√ß√ľn favorit listi. Admin StreamingTitle-dan asńĪlńĪ
/// olmadńĪńüńĪ √ľ√ß√ľn TMDB id + snapshot saxlanńĪlńĪr.
model StreamingTitleFavorite {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId Int
  kind   String

  // Snapshot
  titleSnap     String
  posterUrlSnap String?
  yearSnap      Int?

  createdAt DateTime @default(now())

  @@unique([userId, tmdbId, kind])
  @@index([userId])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Testimonials (customer reviews on homepage) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model Testimonial {
  id            String   @id @default(cuid())
  name          String
  avatarUrl     String?
  text          String
  rating        Int      @default(5)
  // GAME | PS_PLUS | GIFT_CARD | ACCOUNT_CREATION
  platform      String   @default("GAME")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  // Source order this review was written from (via post-purchase email invite).
  transactionId String?  @unique
  createdAt     DateTime @default(now())
}

// Post-purchase review invite. Created when an order is marked SUCCESS;
// emailed to the customer with a unique token URL. One per transaction.
model ReviewInvite {
  id            String    @id @default(cuid())
  token         String    @unique
  transactionId String    @unique
  userId        String
  // Snapshot for rendering the review page even if the source row changes.
  productTitle  String
  // GAME | PS_PLUS | GIFT_CARD | ACCOUNT_CREATION ‚ÄĒ used for the testimonial platform.
  productType   String
  usedAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([userId])
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Global settings (single row, id = "global") ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

model Settings {
  id                              String @id @default("global")
  // Multiplier applied to TRY prices. Stored as float for simplicity.
  tryToAznRate                    Float  @default(0.053)
  // Legacy: global profit margin in percent, e.g. 20 means +20%.
  profitMarginPct                 Float  @default(20)
  // Per-category profit margins (%)
  profitMarginGamesPct            Float  @default(20)
  profitMarginGiftCardsPct        Float  @default(20)
  profitMarginPsPlusPct           Float  @default(20)
  // Legacy: % of purchase price paid to referrer. Kept for back-compat;
  // the active formula is `referralProfitSharePct` below.
  affiliateRatePct                Float  @default(5)
  // % of the store's profit margin shared with the referrer per purchase.
  // Default 20 ‚Üí at a 20% margin, the referrer effectively gets 4% of revenue.
  referralProfitSharePct          Float  @default(20)
  // PS Store alt kateqoriyalarńĪ √ľ√ß√ľn final satńĪŇü m…ôbl…ôńüi √ľz…ôrind…ôn referal faizi.
  // 0 yazńĪldńĪqda h…ômin m…ôhsul tipind…ô referal komissiyasńĪ bańülanńĪr.
  referralGamesPct                Float  @default(0)
  referralPsPlusPct               Float  @default(0)
  referralGiftCardsPct            Float  @default(0)
  referralAccountCreationPct      Float  @default(0)
  // Streaming abun…ôlikl…ôri √ľ√ß√ľn ayrńĪca komissiya faizi ‚ÄĒ final qiym…ôt √ľz…ôrind…ôn t…ôtbiq olunur
  // (oyunlardan f…ôrqli olaraq cost izl…ônmir). Default 10%.
  referralStreamingProfitSharePct Float  @default(10)
  // R…ôy yazan istifad…ô√ßinin affiliate linkind…ôn g…ôl…ôn alńĪŇülardan qazandńĪńüńĪ %.
  // Final satńĪŇü m…ôbl…ôńüi √ľz…ôrind…ôn t…ôtbiq olunur. Default 5%.
  reviewAffiliateRatePct          Float  @default(5)

  // Bank card the customer transfers funds to during manual deposit.
  depositCardNumber String?
  depositCardHolder String?

  updatedAt DateTime @updatedAt
}

// ‚ĒÄ‚ĒÄ‚ĒÄ Search Suggestions ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Header axtarńĪŇü modalńĪnda "Populyar axtarńĪŇülar" pill…ôrini admin idar…ô edir.
// H…ôr s…ôtir: bir m…ôtn (label) + lucide-react ikonu (iconKey enum-undan biri).

model SearchSuggestion {
  id        String   @id @default(cuid())
  label     String
  // Bax: components/NavSearch.tsx-d…ô iconKey ‚Üí komponent map-i.
  // GAMEPAD | GIFT | TV | FILM | SPARKLES | SEARCH | TROPHY | CROWN | MUSIC | BRAIN
  iconKey   String   @default("SEARCH")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
