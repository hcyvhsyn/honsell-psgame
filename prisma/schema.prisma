// Honsell PS Store — Prisma schema
// Provider: PostgreSQL (Supabase).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / Users ─────────────────────────────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  phone        String?
  passwordHash String
  role         String  @default("USER") // USER | ADMIN

  // Admin tərəfindən bloklanan hesablar — login və ödəniş endpoint-ləri bunu yoxlayır.
  disabled    Boolean   @default(false)
  disabledAt  DateTime?
  disabledReason String?

  // Qeydiyyatda "Bizi haradan eşitdiniz?" cavabı (məcburi seçim).
  // Dəyərlər: INSTAGRAM | TIKTOK | FRIEND | OTHER (bax lib/heardAbout.ts).
  // Köhnə hesablarda boş ola bildiyi üçün DB-də nullable saxlanılır.
  heardAboutSource String?

  // Optional profile fields edited from /profile/settings.
  birthDate DateTime?
  gender    String? // "MALE" | "FEMALE" | "OTHER"
  /// Avatar şəkil URL-i — icmallar və profil sahələrində göstərilir.
  /// Boş olarsa client tərəfdə hərfli avatar (initial badge) çəkilir.
  avatarUrl String?

  emailVerified Boolean   @default(false)
  otpCode       String?
  otpExpiresAt  DateTime?
  // Brute-force qoruması: səhv OTP girişləri sayılır, müəyyən həddən sonra
  // otpLockedUntil tarixinə qədər verify-otp endpoint-i 429 qaytarır.
  otpAttempts   Int       @default(0)
  otpLockedUntil DateTime?

  // Set when an admin manually creates the account. The user receives an email
  // with a one-time link → /set-password?token=… that lets them choose a
  // password and verifies their email in one step.
  setPasswordToken          String?   @unique
  setPasswordTokenExpiresAt DateTime?

  // Login activity — yenilənir hər uğurlu login-də (admin paneldən izləmə üçün).
  lastLoginAt        DateTime?
  lastLoginIp        String?
  lastUserAgent      String?
  loginCount         Int       @default(0)

  // Marketinq (endirim bülleteni) — opt-out və son göndəriş izləməsi.
  // marketingUnsubscribedAt qeyri-null isə bu istifadəçiyə toplu marketinq
  // göndərilmir (sifariş/abunəlik kimi əməliyyat e-poçtları təsirlənmir).
  marketingUnsubscribedAt DateTime?
  lastDigestSentAt        DateTime?

  // Wallet (stored in AZN, scaled by 100 to keep integer math clean)
  walletBalance Int @default(0) // depozit / ödəniş üçün əsas cüzdan

  /**
   * Loyalty cashback bu balansa yığılır (cüzdandan ayrı).
   */
  cashbackBalanceCents Int @default(0)

  /**
   * Referaldan komissiya ilə düşən balans — ödənişdə ayrıca seçilir.
   */
  referralBalanceCents Int @default(0)

  // Affiliate / referral
  referralCode String  @unique
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referrals")

  // @deprecated — köhnə "Sponsorlu" boolean. Müştəri seqmenti artıq `tierId`
  // ilə idarə olunur (bax: CustomerTier / ReferralRate). Bu sütunlar geri-uyğunluq
  // üçün saxlanılır və sonrakı təmizlik miqrasiyasında silinəcək.
  isSponsored Boolean   @default(false)
  sponsoredAt DateTime?

  // Müştəri seqmenti — referal komissiya faizləri seqmentə görə dəyişir.
  // NULL = default (isDefault) seqment. Bax: CustomerTier / ReferralRate.
  tierId String?
  tier   CustomerTier? @relation(fields: [tierId], references: [id])

  // PSN delivery accounts (one user can have many; one is marked default).
  psnAccounts PsnAccount[]
  // Epic Games (Türkiye) delivery accounts we created for the user.
  epicAccounts EpicAccount[]

  transactions Transaction[] @relation("UserTransactions")
  commissions  Transaction[] @relation("CommissionBeneficiary")

  subscriptions Subscription[]

  favorites Favorite[]

  discountDigests DiscountDigestNotification[]

  // Tərk edilmiş səbət xatırlatması üçün serverə sinxronlaşdırılan səbət şəkli.
  cartSnapshot CartSnapshot?

  // Marketinq kampaniyaları — yaratdığı (admin) və alıcısı olduğu kampaniyalar.
  createdCampaigns   Campaign[]          @relation("CampaignCreator")
  campaignRecipients CampaignRecipient[]

  referralCycleResults ReferralCycleResult[]

  gameReviews     GameReview[]
  reviewReactions ReviewReaction[]
  reviewComments  ReviewComment[]

  // Honsell İcması — sərbəst topluluq divarı (postlar + reaksiyalar + şərhlər).
  communityPosts          CommunityPost[]
  communityPostReactions  CommunityPostReaction[]
  communityPostComments   CommunityPostComment[]

  // Streaming icmal sistemi — etibarlı istifadəçilərin yazdığı icmallar admin
  // moderasiyası olmadan dərhal APPROVED kimi yayımlanır.
  streamingReviewTrusted   Boolean                   @default(false)
  streamingReviews         StreamingReview[]
  streamingReviewReactions StreamingReviewReaction[]
  streamingTitleFavorites  StreamingTitleFavorite[]

  // Honsell hədiyyə kartları — istifadəçinin aldığı və aktivləşdirdiyi kartlar.
  honsellGiftCardsPurchased HonsellGiftCard[] @relation("HonsellGiftCardPurchases")
  honsellGiftCardsRedeemed  HonsellGiftCard[] @relation("HonsellGiftCardRedemptions")

  // Admin paneldən bu istifadəçi haqqında yazılan daxili qeydlər.
  adminNotes          AdminNote[]      @relation("AdminNoteTarget")
  adminNotesAuthored  AdminNote[]      @relation("AdminNoteAuthor")
  // Admin tərəfindən bu istifadəçi üzərində aparılan əməliyyatlar.
  adminAuditEntries   AdminAuditLog[]  @relation("AdminAuditTarget")
  adminActionsTaken   AdminAuditLog[]  @relation("AdminAuditActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PSN delivery accounts (one user → many PSN logins) ───────────────────────

model PsnAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Friendly nickname shown in dropdowns ("Main", "Brother", "Eu Region")
  label       String
  psnEmail    String
  psnPassword String // encrypt at rest in production

  /// Console model the account is bound to. "PS4" | "PS5".
  psModel String @default("PS5")

  isDefault Boolean @default(false)

  transactions  Transaction[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// A customer's Epic Games (Türkiye) account — created by us on their behalf
/// when they buy the Epic account-creation service, then used to deliver Epic
/// game purchases. Mirrors PsnAccount but with Epic-specific fields.
model EpicAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Friendly nickname shown in dropdowns (defaults to the display name).
  label        String
  firstName    String
  lastName     String
  /// YYYY-MM-DD as entered by the customer.
  birthDate    String
  epicEmail    String
  epicPassword String // encrypt at rest in production
  /// Requested Epic display name. Epic display names are unique, so the final
  /// one may differ slightly from what the customer asked for.
  displayName  String

  isDefault Boolean @default(false)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Game {
  id         String  @id @default(cuid())
  // Stable product id used to upsert during scraping. For PS Store this is the
  // raw PS product id; for Epic it is namespaced as `epic:<namespace>:<offerId>`
  // so the two storefronts never collide on this @unique column.
  productId  String  @unique
  title      String
  imageUrl   String?
  productUrl String?

  // Which storefront this row was scraped from. "PS" | "EPIC".
  store String @default("PS")
  // Epic catalog namespace (needed to build the product page link). NULL for PS.
  namespace String?
  // Epic genre tag names (e.g. ["Action","RPG"]). Powers the PC category filter.
  // Empty for PS rows. Populated from Epic `tags` where groupName = "genre".
  genres String[] @default([])

  // PS4 | PS5 — derived from the productId code (CUSA/PPSA). "PC" for Epic.
  platform String?

  // GAME | ADDON | CURRENCY | OTHER — derived from storeDisplayClassification
  // GAME      → FULL_GAME, GAME_BUNDLE, PREMIUM_EDITION, null (concept page)
  // ADDON     → ADD_ON_PACK (DLC, costumes, season passes)
  // CURRENCY  → VIRTUAL_CURRENCY (cash cards)
  // OTHER     → themes, avatars, demos, anything else
  productType String @default("GAME")

  // Source prices in TRY, scaled by 100 (kuruş). Never shown to users.
  // For Epic rows this holds the Türkiye (country=TR) price.
  priceTryCents    Int
  discountTryCents Int? // null when no discount is active
  discountEndAt    DateTime? // when the active discount expires (from PS Store)
  // Endirim ilk dəfə aşkar olunan an (null→endirim keçidində scrape təyin edir,
  // endirim bitəndə təmizlənir). Həftəlik "yeni endirimlər" bülleteni bunu
  // "son N gündə endirimə düşənlər" filtri üçün istifadə edir.
  discountStartedAt DateTime?

  // Epic only: Azərbaycan (country=AZ) prices in USD, scaled by 100 (cents).
  // NULL for PS rows. Stored alongside TRY so the dual-currency sale logic can
  // be decided later; v1 still prices off priceTryCents.
  priceUsdCents    Int?
  discountUsdCents Int?

  // Rich media + metadata scraped from PS Store listing pages
  heroImageUrl String? // BACKGROUND-role media (wide hero/cover)
  trailerUrl   String? // PREVIEW-role media (mp4 trailer URL)
  screenshots  Json? // String[] — additional IMAGE-role media URLs
  editionLabel String? // e.g. "Tam Sürüm Oyun", "Premium Sürüm"

  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  lastScrapedAt DateTime @default(now())

  // 512-dim vector from OpenAI `text-embedding-3-small` (dimensions=512). Powers
  // semantic search and "similar games" recommendations in the cart. NULL until
  // the backfill job or scraper post-step populates it. `embeddingHash` is a
  // short fingerprint of the text we embedded (title + edition + platform);
  // when it changes, the row is re-embedded.
  embedding     Float[]
  embeddingHash String?

  transactions Transaction[]
  banners      Banner[]
  collections  CollectionGame[]
  favorites    Favorite[]
  reviews      GameReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platform])
  @@index([productType])
  @@index([title])
  @@index([isFeatured])
  @@index([store])
}

// Caches LLM-generated "Bunu nəzərdə tutdunuz?" corrections so repeated typos
// don't pay the OpenAI cost twice. Lookup key is the lowercased, trimmed
// query. Distinct from the admin-curated SearchSuggestion popular pills.
model SearchTypoSuggestion {
  id         String   @id @default(cuid())
  queryNorm  String   @unique
  suggestion String
  hits       Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([queryNorm])
}

// ─── Collections (curated game lists) ─────────────────────────────────────────

model Collection {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  games CollectionGame[]

  @@index([isActive, sortOrder])
  @@index([isFeatured])
}

model CollectionGame {
  collectionId String
  gameId       String
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  game       Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([collectionId, gameId])
  @@index([collectionId, position])
  @@index([gameId])
}

// ─── Service Products (TRY Balans, PS Plus, Account Creation) ────────────────

model ServiceProduct {
  id            String  @id @default(cuid())
  // ACCOUNT_CREATION | TRY_BALANCE | PS_PLUS
  type          String
  title         String
  description   String?
  imageUrl      String?
  // Qiymət (AZN qəpiklə)
  priceAznCents Int

  // Əlavə məlumatlar:
  // TRY_BALANCE üçün: neçə TRY-dir (məs: 250, 500)
  // PS_PLUS üçün: tier (ESSENTIAL/EXTRA/DELUXE) və durationMonths (1, 3, 12)
  metadata Json?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  codes         ServiceCode[]
  transactions  Transaction[]
  subscriptions Subscription[]
  banners       Banner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model ServiceCode {
  id               String         @id @default(cuid())
  serviceProductId String
  serviceProduct   ServiceProduct @relation(fields: [serviceProductId], references: [id])

  code   String // 12 rəqəmli e-pin və s.
  isUsed Boolean @default(false)

  transactions Transaction[]

  createdAt DateTime @default(now())

  @@index([serviceProductId, isUsed])
}

// ─── Honsell Gift Cards (öz markamızın hədiyyə kartları) ─────────────────────
//
// Müştəri 5/10/20/50/100/200/500/1000 AZN nominalında kart alır, sistem 11
// simvollu unikal kod generasiya edir və alıcıya email ilə göndərilir.
// İstənilən başqa istifadəçi həmin kodu "/profile/hediyye-kart" səhifəsində
// daxil edərək cüzdan balansına məbləği köçürə bilər. Kodlar 1 il etibarlıdır.

model HonsellGiftCard {
  id             String  @id @default(cuid())
  // 11 simvollu unikal kod — admin tərəfindən manual daxil edilir.
  // PENDING vəziyyətində NULL ola bilər; admin kod daxil etdikdən sonra dolur.
  code           String? @unique
  // Kartın AZN qəpiklə nominalı (5 AZN → 500).
  amountAznCents Int
  // PENDING | ACTIVE | REDEEMED — alışdan sonra PENDING, admin kod daxil etdikdə ACTIVE,
  // başqa istifadəçi aktivləşdirdikdə REDEEMED. Bir kart yalnız bir dəfə istifadə oluna bilər.
  status         String  @default("PENDING")

  // Admin kodu daxil edib təslim etdiyi vaxt.
  deliveredAt DateTime?

  // Alıcı (system-də qeydiyyatlı istifadəçi olmalıdır).
  purchasedById         String?
  purchasedBy           User?    @relation("HonsellGiftCardPurchases", fields: [purchasedById], references: [id])
  // Alış üçün yaradılmış SERVICE_PURCHASE tranzaksiyasının id-si (audit).
  purchaseTransactionId String?
  purchasedAt           DateTime @default(now())

  // Aktivləşdirən istifadəçi (özü ola bilər, başqası da). NULL qaldıqca ACTIVE.
  redeemedById        String?
  redeemedBy          User?     @relation("HonsellGiftCardRedemptions", fields: [redeemedById], references: [id])
  redeemTransactionId String?
  redeemedAt          DateTime?

  // Bitmə tarixi — alışdan 1 il sonra. Bu tarixdən sonra aktivləşdirmə bloklanır.
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([purchasedById])
  @@index([redeemedById])
}

// ─── Product Gifts (məhsulu dostuna hədiyyə et) ──────────────────────────────
//
// Müştəri istənilən məhsulu (oyun, abunəlik və s.) "hədiyyə" olaraq alır.
// Ödəniş uğurlu olan kimi sistem 11 simvollu unikal kod yaradır və alıcıya
// göstərir/email edir. Alıcı kodu dostuna verir; dost saytda qeydiyyatdan
// keçib "/hediyye-ac" səhifəsində kodu daxil edərək hədiyyəni açır — məhsul
// onun adına PENDING fulfillment sifarişi kimi yaradılır və admin tərəfindən
// adi sifariş kimi çatdırılır. Honsell hədiyyə kartından (cüzdana balans
// köçürən) fərqlidir: burada alan konkret məhsulu öz hesabına alır.
//
// Cədvəl lib/prisma.ts-dəki ensure-once pattern ilə runtime-da yaradılır
// (formal prisma migration əvəzinə — AiKnowledge ilə eyni üsul).
model ProductGift {
  id   String @id @default(cuid())
  // 11 simvollu unikal kod (HonsellGiftCard ilə eyni alfabet/format).
  code String @unique

  // UNCLAIMED | CLAIMED — alışdan sonra UNCLAIMED, dost açdıqda CLAIMED.
  status String @default("UNCLAIMED")

  // Məhsul snapshot-u — claim vaxtı dostun adına sifarişi qurmaq üçün.
  // GAME | PS_PLUS | EA_PLAY | TRY_BALANCE | STREAMING | PLATFORM |
  // ACCOUNT_CREATION | EPIC_ACCOUNT_CREATION | HONSELL_GIFT_CARD
  productKind      String
  gameId           String?
  serviceProductId String?
  // Oyunlar üçün storefront: "PS" | "EPIC".
  store            String?
  titleSnap        String
  imageSnap        String?
  amountAznCents   Int
  // Alıcının dostuna yazdığı opsional mesaj.
  giftMessage      String?

  // Alıcı (hədiyyəni alan müştəri) — relation qurmadan id saxlanılır.
  purchasedById         String
  purchaseTransactionId String?
  purchasedAt           DateTime @default(now())

  // Açan dost.
  claimedById              String?
  claimedAt                DateTime?
  // Açıldıqda dostun adına yaradılan PENDING fulfillment sifarişinin id-si.
  fulfillmentTransactionId String?

  // Bitmə tarixi — alışdan 1 il sonra. Bu tarixdən sonra açılma bloklanır.
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([purchasedById])
  @@index([claimedById])
}

// ─── Transactions (deposits, purchases, commissions) ──────────────────────────

model Transaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserTransactions", fields: [userId], references: [id])

  // DEPOSIT | PURCHASE | COMMISSION | SERVICE_PURCHASE
  type   String
  // PENDING | SUCCESS | FAILED
  status String @default("SUCCESS")

  // Amount in qəpik (AZN * 100). Positive = credit, negative = debit.
  amountAznCents Int

  // Customer savings on this transaction (AZN qəpik, ≥ 0). Set on PURCHASE
  // rows when a discount was active at checkout: original − final per unit ×
  // qty. Profile aggregates this to display lifetime savings.
  savingsAznCents Int @default(0)

  // Mağazanın maya dəyəri snapshot-u (AZN qəpik) — alış anında FX rate ilə
  // hesablanıb saxlanılır ki, gələcəkdə rate dəyişəndə mənfəət hesabatı
  // pozulmasın. 0 = naməlum (köhnə tranzaksiyalar və ya scrape-də qiymət olmayan
  // oyunlar). Yalnız PURCHASE sətirlərində mənalıdır.
  costAznCents Int @default(0)

  // Optional purchase details
  gameId String?
  game   Game?   @relation(fields: [gameId], references: [id])

  serviceProductId String?
  serviceProduct   ServiceProduct? @relation(fields: [serviceProductId], references: [id])

  serviceCodeId String?
  serviceCode   ServiceCode? @relation(fields: [serviceCodeId], references: [id])

  // Which PSN account this purchase was delivered to. NULL for non-PURCHASE
  // rows (DEPOSIT, COMMISSION) and for legacy data created before multi-PSN.
  psnAccountId String?
  psnAccount   PsnAccount? @relation(fields: [psnAccountId], references: [id])

  // Which Epic account this purchase is for (PC games), or the account created
  // by an EPIC_ACCOUNT_CREATION order. NULL for everything else.
  epicAccountId String?
  epicAccount   EpicAccount? @relation(fields: [epicAccountId], references: [id])

  // For COMMISSION rows: the user who earned the commission
  beneficiaryId String?
  beneficiary   User?   @relation("CommissionBeneficiary", fields: [beneficiaryId], references: [id])

  // Free-form metadata (e.g. masked card, gateway ref)
  metadata String?

  // Manual-deposit receipt URL (uploaded by the customer, reviewed by admin)
  receiptUrl String?

  createdAt DateTime @default(now())

  @@index([status, type])
}

// ─── PS Plus subscriptions (auto-renew, expiry tracking) ─────────────────────

model Subscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceProductId String
  serviceProduct   ServiceProduct @relation(fields: [serviceProductId], references: [id])

  // Optional PSN account this subscription is bound to (nullable for legacy/unbound).
  psnAccountId String?
  psnAccount   PsnAccount? @relation(fields: [psnAccountId], references: [id])

  // Snapshot fields so the row stays meaningful even if the ServiceProduct row changes.
  tier           String // ESSENTIAL | EXTRA | DELUXE
  durationMonths Int // 1 | 3 | 12 — used as the auto-renew period.
  priceAznCents  Int // Last-known renewal price in qəpik.

  startsAt  DateTime
  expiresAt DateTime

  // ACTIVE | CANCELLED | EXPIRED
  status String @default("ACTIVE")

  autoRenew Boolean @default(false)

  // Notification de-dup. Stores the expiry-date these reminders were sent for,
  // so a subscription that gets renewed gets a fresh reminder cycle.
  remind3SentAt    DateTime?
  remind1SentAt    DateTime?
  lowBalanceSentAt DateTime?

  // Last successful renewal info (admin debugging).
  lastRenewedAt   DateTime?
  lastRenewalTxId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, expiresAt])
  @@index([autoRenew, expiresAt])
}

// ─── PS Store scrape history ──────────────────────────────────────────────────

model ScrapeRun {
  id            String    @id @default(cuid())
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  // RUNNING | SUCCESS | PARTIAL | FAILED
  status        String    @default("RUNNING")
  // PS_STORE | STREAMING — ayırt etmek üçün, eyni cədvəldə hər iki növ run saxlanır.
  kind          String    @default("PS_STORE")
  // Total unique products extracted from PS Store before persisting.
  scrapedCount  Int       @default(0)
  // Rows actually upserted into Game (== scrapedCount on success).
  upsertedCount Int       @default(0)
  // Streaming run-larda platform breakdown — JSON: { netflix: { added, removed, updated, errors }, ... }
  summary       Json?
  error         String?

  changes ScrapeChange[]

  @@index([startedAt])
  @@index([kind, startedAt])
}

// ─── Banners (homepage hero carousel) ────────────────────────────────────────

model Banner {
  id             String   @id @default(cuid())
  title          String?
  subtitle       String?
  imageUrl       String
  // Mobil cihazlar üçün opsional alternativ şəkil. Boş olduqda `imageUrl` istifadə olunur.
  mobileImageUrl String?
  linkUrl        String?
  // LINK | ADD_TO_CART
  actionType     String   @default("LINK")
  // ADD_TO_CART banneri ya bir oyuna (gameId), ya da bir xidmət/məhsula
  // (serviceProductId — streaming, platform, PS Plus, EA Play, hədiyyə kartı...)
  // referans verir. Yalnız biri doldurulur.
  gameId         String?
  game           Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  serviceProductId String?
  serviceProduct   ServiceProduct? @relation(fields: [serviceProductId], references: [id], onDelete: SetNull)
  // Mətn blokunun yeri (9-nöqtəli ızgara) — desktop və mobil üçün ayrıca —
  // və mətn teması (açıq/tünd). Bax: components/bannerLayout.ts
  contentPosition       String @default("BOTTOM_LEFT")
  contentPositionMobile String @default("BOTTOM_LEFT")
  contentTheme          String @default("LIGHT")
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  /// Bannerin göstəriləcəyi səhifə: HOME | PLAYSTATION | (gələcəkdə yeni scope-lar
  /// əlavə oluna bilər). Hər scope-un öz sıralaması və idarəsi var.
  scope          String   @default("HOME")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([gameId])
  @@index([serviceProductId])
  @@index([scope, isActive, sortOrder])
}

// ─── Navbar category assets ──────────────────────────────────────────────────

/// Navbar-dakı "Kateqoriyalar" dropdown kartları üçün admin tərəfindən idarə
/// olunan kvadrat şəkil və mətn dataları. `key` public kodda sabit təriflərlə
/// uyğunlaşır; admin panel sadəcə bu satırları yeniləyir.
model CategoryAsset {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  href        String
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

/// Streaming/music platforması (HBO Max, Netflix, Prime Video, YouTube Premium…).
/// Admin tərəfindən yaradılır/redaktə/silinir. Public platforma səhifələri
/// (/streaming/[slug], /music/[slug]) və admin bu cədvəldən oxuyur.
/// devices/vpnRequired/platformImageUrl product metadata-da saxlanır (paket səviyyəsində).
model StreamingPlatform {
  id          String   @id @default(cuid())
  code         String   @unique // PRIME_VIDEO
  slug         String   @unique // prime
  label        String
  category     String   @default("STREAMING") // STREAMING | MUSIC
  tagline      String   @default("")
  description  String   @default("")
  heroImageUrl String?
  sortOrder    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ─── Streaming Content (films & series available on streaming services) ───────

/// Bir film və ya seriya. Streaming xidmətinin (HBO Max, Gain, YouTube Premium,
/// Netflix) Azərbaycanda yayımlanan kataloqunu admin manual olaraq saxlayır.
/// `azAvailable=false` olan title-lar public-də gizlənir.
model StreamingTitle {
  id                String  @id @default(cuid())
  // Public path-larda istifadə olunan unikal slug (məs: "stranger-things").
  slug              String  @unique
  title             String
  // MOVIE | SERIES
  kind              String  @default("MOVIE")
  // STREAMING_SERVICES-dən biri: HBO_MAX | GAIN | YOUTUBE_PREMIUM | NETFLIX
  service           String
  posterUrl         String?
  backdropUrl       String?
  year              Int?
  // String massivi JSON kimi: ["Drama", "Sci-Fi"]
  genres            Json?
  description       String?
  // Azərbaycanda yayımlanır? Public listing-də yalnız true olanlar göstərilir.
  azAvailable       Boolean @default(true)
  isActive          Boolean @default(true)
  sortOrder         Int     @default(0)
  // Xarici provayder ID-si (OMDb halında IMDb ID, məs: "tt0372784"). Avtomatik
  // doldurulduqda dublikatın qarşısını almaq üçün istifadə olunur.
  externalId        String?
  // OMDb-dən çəkilən orijinal dil kodu (məs: "en", "tr", "ru").
  originalLanguage  String?
  // Admin manual seçir — ISO dil kodları massivi: ["az", "tr", "en"]
  dubbedLanguages   Json?
  subtitleLanguages Json?
  // YouTube trailer linki (məs: "https://www.youtube.com/watch?v=abc123").
  // TMDB-dən orijinal dildə rəsmi trailer üstün, manual override mümkündür.
  trailerUrl        String?

  // TMDB-dən scrape enrichment zamanı doldurulan reytinq/populyarlıq metrikləri.
  // Reytinq sıralaması (yüksək → aşağı) və "ən çox baxılan" üçün istifadə olunur.
  tmdbRating     Float? // vote_average, 0-10 (IMDb ilə ~üst-üstə düşür)
  tmdbVoteCount  Int? // vote_count — reytinq tie-breaker / az-səsli başlıqları filtr
  tmdbPopularity Float? // popularity — trend/"ən çox baxılan" skoru

  featured       StreamingFeatured[]
  availabilities ContentAvailability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([service, isActive, azAvailable])
  @@index([service, sortOrder])
  @@index([externalId])
  @@index([service, tmdbPopularity])
  @@index([service, tmdbRating])
}

/// Streaming overview və ya konkret service səhifəsində göstərilən banner
/// elementi. Admin hər scope üçün ayrıca banner siyahısı qurur.
model StreamingFeatured {
  id        String         @id @default(cuid())
  // "OVERVIEW" və ya konkret service kodu (HBO_MAX, GAIN, YOUTUBE_PREMIUM, NETFLIX)
  scope     String
  titleId   String
  title     StreamingTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)
  isActive  Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([scope, isActive, sortOrder])
  @@index([titleId])
}

// ─── Streaming customer reviews ───────────────────────────────────────────────

/// Müştərinin TMDB film/serial üzrə yazdığı icmal. tmdbId+kind referansdır;
/// admin StreamingTitle-dan asılı deyil. Snapshot sahələri TMDB datasını saxlayır
/// ki, icmal göstərmək üçün hər dəfə TMDB-yə müraciət etməyək.
model StreamingReview {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// TMDB id (movie/tv) — bizim StreamingTitle row-dan asılı olmadan icmal yazılır.
  tmdbId  Int
  /// MOVIE | SERIES — TMDB endpoint seçimi üçün lazımdır.
  kind    String
  /// Müştərinin baxdığı platforma: HBO_MAX | GAIN | YOUTUBE_PREMIUM | NETFLIX
  service String

  /// 1–10
  rating        Int
  /// İcmal mətni (cəza-filterdən keçir).
  body          String
  /// İzləmə dili — tr | ru | en | original
  watchLanguage String?
  /// İcmalda spoiler varmı? Spoiler-li icmallar başqaları üçün blur ilə göstərilir,
  /// klik etdikdə açılır.
  spoiler       Boolean @default(false)

  /// PENDING | APPROVED | REJECTED
  status         String  @default("PENDING")
  rejectedReason String?

  // Snapshot — icmali göstərmək üçün TMDB-dən kopyalanır
  titleSnap       String
  posterUrlSnap   String?
  backdropUrlSnap String?
  yearSnap        Int?
  genresSnap      Json?

  reactions StreamingReviewReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Eyni istifadəçi eyni filmi / serialı yalnız bir dəfə icmal edə bilir.
  @@unique([userId, tmdbId, kind])
  @@index([status, createdAt])
  @@index([tmdbId, kind, status])
  @@index([service, status])
}

model StreamingReviewReaction {
  id        String          @id @default(cuid())
  reviewId  String
  review    StreamingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// LIKE | DISLIKE
  kind      String
  createdAt DateTime        @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

/// Müştərinin TMDB film/serial üçün favorit listi. Admin StreamingTitle-dan asılı
/// olmadığı üçün TMDB id + snapshot saxlanılır.
model StreamingTitleFavorite {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId Int
  kind   String

  // Snapshot
  titleSnap     String
  posterUrlSnap String?
  yearSnap      Int?

  createdAt DateTime @default(now())

  @@unique([userId, tmdbId, kind])
  @@index([userId])
}

// ─── Testimonials (customer reviews on homepage) ──────────────────────────────

model Testimonial {
  id            String   @id @default(cuid())
  name          String
  avatarUrl     String?
  text          String
  rating        Int      @default(5)
  // GAME | PS_PLUS | GIFT_CARD | ACCOUNT_CREATION
  platform      String   @default("GAME")
  // Müştərinin rəy yazdığı konkret məhsulun adı (snapshot). Alış sonrası dəvətdə
  // və ya anasayfada aldığı məhsulu seçəndə doldurulur. Köhnə/ümumi rəylərdə boş.
  productTitle  String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  // Source order this review was written from (via post-purchase email invite).
  transactionId String?  @unique
  createdAt     DateTime @default(now())
}

// Post-purchase review invite. Created when an order is marked SUCCESS;
// emailed to the customer with a unique token URL. One per transaction.
model ReviewInvite {
  id            String    @id @default(cuid())
  token         String    @unique
  transactionId String    @unique
  userId        String
  // Snapshot for rendering the review page even if the source row changes.
  productTitle  String
  // GAME | PS_PLUS | GIFT_CARD | ACCOUNT_CREATION — used for the testimonial platform.
  productType   String
  usedAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([userId])
}

// ─── Global settings (single row, id = "global") ──────────────────────────────

model Settings {
  id                              String @id @default("global")
  // Multiplier applied to TRY prices. Stored as float for simplicity.
  tryToAznRate                    Float  @default(0.053)
  // Multiplier applied to Epic Azərbaycan (USD) prices → AZN. Used only by
  // Epic positional pricing (USD reference price → AZN).
  usdToAznRate                    Float  @default(1.7)
  // Epic qiymət mövqeyi (%): maya (TR) ilə referans (AZ) arasında.
  // 0 = maya qiyməti, 100 = AZ referans qiyməti, 50 = orta nöqtə.
  epicPositionPct                 Float  @default(50)
  // Epic döşəmə hesabında tələb olunan minimal mənfəət buferi (%). Final qiymət
  // heç vaxt maya + referal + bu bufer-dən aşağı düşmür.
  epicMinProfitPct                Float  @default(10)
  // Legacy: global profit margin in percent, e.g. 20 means +20%.
  profitMarginPct                 Float  @default(20)
  // Per-category profit margins (%)
  profitMarginGamesPct            Float  @default(20)
  profitMarginGiftCardsPct        Float  @default(20)
  profitMarginPsPlusPct           Float  @default(20)
  // Legacy: % of purchase price paid to referrer. Kept for back-compat;
  // the active formula is `referralProfitSharePct` below.
  affiliateRatePct                Float  @default(5)
  // % of the store's profit margin shared with the referrer per purchase.
  // Default 20 → at a 20% margin, the referrer effectively gets 4% of revenue.
  referralProfitSharePct          Float  @default(20)
  // PS Store alt kateqoriyaları üçün final satış məbləği üzərindən referal faizi.
  // 0 yazıldıqda həmin məhsul tipində referal komissiyası bağlanır.
  referralGamesPct                Float  @default(0)
  // "Sponsorlu" müştərilər üçün oyun referal faizi. Sponsorlu müştərinin dəvət
  // etdiyi istifadəçilərin oyun alışlarına standart referralGamesPct əvəzinə bu
  // tətbiq olunur. Default 8%.
  sponsoredReferralGamesPct       Float  @default(8)
  referralPsPlusPct               Float  @default(0)
  referralGiftCardsPct            Float  @default(0)
  referralAccountCreationPct      Float  @default(0)
  // Streaming abunəlikləri üçün ayrıca komissiya faizi — final qiymət üzərindən tətbiq olunur
  // (oyunlardan fərqli olaraq cost izlənmir). Default 10%.
  referralStreamingProfitSharePct Float  @default(10)
  // Rəy yazan istifadəçinin affiliate linkindən gələn alışlardan qazandığı %.
  // Final satış məbləği üzərindən tətbiq olunur. Default 5%.
  reviewAffiliateRatePct          Float  @default(5)

  // Bank card the customer transfers funds to during manual deposit.
  depositCardNumber String?
  depositCardHolder String?

  updatedAt DateTime @updatedAt
}

// ─── Müştəri seqmentləri + referal faiz matrisi ──────────────────────────────
//
// Referal komissiya faizləri artıq (seqment × hədəf) matrisi ilə idarə olunur.
// Hər istifadəçi bir seqmentə (CustomerTier) aiddir; `User.tierId` NULL isə
// `isDefault = true` olan seqment tətbiq edilir. Hər seqmentin hər hədəf üçün
// öz faizi var (ReferralRate). Hədəf ya PS Store kateqoriyasıdır (PS_GAMES,
// PS_PLUS, GIFT_CARDS, ACCOUNT_CREATION), ya da konkret ServiceProduct sətiridir
// (SERVICE_PRODUCT — streaming/platform abunəlikləri, hər müddət ayrıca).
//
// Köhnə "Sponsorlu" mexanizmi bu sistemə miqrasiya olunub: seed "adi" (default)
// və "sponsorlu" seqmentlərini yaradır və köhnə faizləri backfill edir.

model CustomerTier {
  id        String   @id @default(cuid())
  // UI etiketi (AZ): "Adi", "Sponsorlu", ...
  name      String
  // Seed/miqrasiya üçün stabil açar: "adi", "sponsorlu", ...
  slug      String   @unique
  // Dəqiq bir sətir true olmalıdır — `tierId = null` olan istifadəçilərə tətbiq edilir.
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  // Admin paneldə badge rəngi (opsional, məs: "#22c55e").
  color     String?

  users User[]
  rates ReferralRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model ReferralRate {
  id     String       @id @default(cuid())
  tierId String
  tier   CustomerTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  // PS_GAMES | PS_PLUS | GIFT_CARDS | ACCOUNT_CREATION | SERVICE_PRODUCT
  targetType String

  // Yalnız targetType = SERVICE_PRODUCT olduqda dolur (streaming/platform müddət
  // sətirləri). Kateqoriya hədəflərində sentinel "" saxlanır — NULL deyil, çünki
  // Postgres NULL-ları unique indeksdə fərqli sayır və `(tier, PS_GAMES, null)`
  // təkrarlanardı. FK qoyulmur; məhsul silinsə bu sətir orphan qalır (resolve
  // olunmur, zərərsizdir) və seed/admin tərəfindən təmizlənə bilər.
  serviceProductId String @default("")

  ratePct Float   @default(0)
  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tierId, targetType, serviceProductId])
  @@index([tierId, targetType])
  @@index([serviceProductId])
}

// ─── Search Suggestions ──────────────────────────────────────────────────────
// Header axtarış modalında "Populyar axtarışlar" pillərini admin idarə edir.
// Hər sətir: bir mətn (label) + lucide-react ikonu (iconKey enum-undan biri).

model SearchSuggestion {
  id        String   @id @default(cuid())
  label     String
  // Bax: components/NavSearch.tsx-də iconKey → komponent map-i.
  // GAMEPAD | GIFT | TV | FILM | SPARKLES | SEARCH | TROPHY | CROWN | MUSIC | BRAIN
  iconKey   String   @default("SEARCH")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ─── Favorites (wishlist + sale notifications) ───────────────────────────────

model Favorite {
  userId    String
  gameId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // One row per (user, game). Toggle by upsert/delete.
  @@id([userId, gameId])
  @@index([gameId])
  @@index([userId, createdAt])
}

// Dedup table — one row per sale-notification email sent.
// Keyed by (userId, gameId, discountStartedAt) where discountStartedAt is the
// timestamp at which the favorited game first transitioned from no-discount to
// discount during a scrape run. Prevents re-sending if a later scrape run sees
// the same active sale window.
model FavoriteNotification {
  id                String   @id @default(cuid())
  userId            String
  gameId            String
  // Snapshot of the discount start date so a future *new* sale (separate from
  // the one we already notified for) creates a fresh row.
  discountStartedAt DateTime
  sentAt            DateTime @default(now())

  @@unique([userId, gameId, discountStartedAt])
  @@index([gameId])
}

/// Həftəlik endirim bülleteninin göndəriş qeydi. Hər istifadəçiyə bir həftə
/// pəncərəsində yalnız bir dəfə göndərmək üçün dedup açarı (userId + weekStart).
/// weekStart = bülletenin aid olduğu həftənin başlanğıcı (UTC bazən 00:00).
model DiscountDigestNotification {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  gameCount Int      @default(0) // bülletendə neçə endirim göstərildi
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart])
}

/// Login olmuş istifadəçinin səbətinin serverdəki şəkli — tərk edilmiş səbət
/// (abandoned cart) xatırlatma e-poçtları üçün. Səbət əslində brauzerdə
/// (localStorage) saxlanılır; client onu dəyişdikcə /api/cart/sync bu sətri
/// upsert edir. Səbət boşaldıqda (alış / təmizləmə) sətir silinir — yəni
/// mövcud, dolu snapshot = "hələ alınmayıb" deməkdir.
///
/// TƏHLÜKƏSİZLİK: `items` yalnız təhlükəsiz sahələri saxlayır (id, başlıq,
/// şəkil, qiymət, say, productType, store). Hesab açılışı / streaming
/// parolları kimi həssas sahələr serverə YAZILMIR (bax: /api/cart/sync).
model CartSnapshot {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Təmizlənmiş səbət elementləri: [{ id, title, imageUrl, finalAzn, qty, productType, store }]
  items         Json
  itemCount     Int @default(0) // qty cəmi
  totalAznCents Int @default(0) // səbətin ümumi dəyəri (qəpik)

  /// Səbət tərkibinin imzası (id+qty). Dəyişdikdə yeni "tərk" sayılır və
  /// reminderSentAt sıfırlanır ki, yeni tərkib üçün bir dəfə də xatırlatma getsin.
  signature String

  /// Tərk edilmiş səbət xatırlatması göndərilən an. NULL = hələ göndərilməyib.
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  /// Səbətin son toxunulma anı — "tərk edilmiş" yaşını bununla hesablayırıq.
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
  @@index([reminderSentAt])
}

// ─── Reklam / Kampaniya (admin əl ilə göndərdiyi toplu endirim mesajları) ─────
//
// Avtomatik həftəlik bülletendən (DiscountDigestNotification) fərqli olaraq,
// admin burada auditoriyanı (filtr + əllə seçim), oyunları və kanalı (WhatsApp /
// Email) özü seçir. `gamesSnapshot` göndərmə anındakı oyun + qiymət şəklini
// saxlayır ki, sonradan qiymət dəyişsə də tarixçə dəqiq qalsın.
model Campaign {
  id          String  @id @default(cuid())
  title       String
  /// PROMO | REVIEW_INVITE — PROMO: endirimli oyun reklamı; REVIEW_INVITE: alıb
  /// rəy yazmayan müştəriləri rəy yazmağa dəvət (oyun bloku yox, "Rəy yaz" CTA).
  kind        String  @default("PROMO")
  /// Admin yazdığı giriş mətni (oyun bloku avtomatik əlavə olunur).
  messageText String
  sendEmail    Boolean @default(false)
  sendWhatsapp Boolean @default(false)

  /// Göndərmə anında oyunların snapshotu:
  /// [{ productId, title, finalAzn, originalAzn, discountPct }]
  gamesSnapshot Json

  /// DRAFT | SENDING | SENT | FAILED
  status String @default("DRAFT")

  recipientCount Int @default(0)
  emailSent      Int @default(0)
  emailFailed    Int @default(0)
  waSent         Int @default(0)
  waFailed       Int @default(0)

  createdById String?
  createdBy   User?   @relation("CampaignCreator", fields: [createdById], references: [id])

  recipients CampaignRecipient[]
  clicks     CampaignClick[]

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([status, createdAt])
}

/// Kampaniyanın hər bir alıcısı üzrə kanal-statusları (audit / tarixçə).
/// emailStatus / waStatus: PENDING | SENT | FAILED | SKIPPED | N_A
model CampaignRecipient {
  id         String @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  email String
  phone String?

  emailStatus String @default("N_A")
  waStatus    String @default("N_A")
  error       String?

  // Klik izləmə — bu alıcı kampaniya linkinə neçə dəfə / nə vaxt daxil olub.
  clickCount   Int       @default(0)
  firstClickAt DateTime?
  lastClickAt  DateTime?

  clicks CampaignClick[]

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([userId])
}

/// Kampaniya linkinə hər klik bir sətir — hansı alıcı, hansı oyun, nə vaxt.
/// Link `/api/campaigns/click` üzərindən keçir, qeyd alınır və oyun səhifəsinə
/// yönləndirilir.
model CampaignClick {
  id          String  @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   CampaignRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  userId      String?
  productId   String

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([recipientId])
  @@index([campaignId, productId])
}

// ─── FAQ (homepage "Tez-tez verilən suallar") ─────────────────────────────────

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  /// FAQ-ın göstəriləcəyi səhifə: HOME | PLAYSTATION | STREAMING_OVERVIEW |
  /// STREAMING_HBO_MAX | STREAMING_GAIN | STREAMING_NETFLIX | STREAMING_YOUTUBE
  scope     String   @default("HOME")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, isActive, sortOrder])
}

/// Platforma bələdçiləri — "Faydalı başlıqlar" sahələrində göstərilən qısa
/// guide-lar (məs: "HBO Max-ı necə yükləmək olar"). Hər guide bir scope-a
/// bağlanır və müvafiq səhifədə görünür.
model PlatformGuide {
  id        String   @id @default(cuid())
  /// Public path-larda istifadə üçün unikal slug.
  slug      String   @unique
  title     String
  /// Qısa təsvir — kart preview-da göstərilir.
  summary   String?
  /// Tam mətn — markdown yox, plain text saxlanılır (xətt sonu pre-line ilə render).
  body      String
  /// Opsional YouTube video linki — varsa, kartda &laquo;Videoya bax&raquo; düyməsi
  /// göstərilir və klikdə yeni tab-da açılır.
  videoUrl  String?
  /// Scope: HOME | PLAYSTATION | STREAMING_HBO_MAX | STREAMING_GAIN | və s.
  scope     String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, isActive, sortOrder])
}

/// Xəbərlər — admin paneldən idarə olunan platforma-spesifik xəbər/elan/yenilik
/// kartları. Hər xəbər bir scope-a bağlanır (HOME | PLAYSTATION | STREAMING_*),
/// PlayStation, Streaming və Music səhifələrində uyğun scope-lu xəbərlər
/// göstərilir. `isFeatured` true olduqda kart böyük "hero" formatında render
/// olunur.
model NewsArticle {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  /// Qısa anons mətni — kartlarda göstərilir.
  excerpt       String?
  /// Tam mətn — `whitespace-pre-line` ilə render olunur.
  body          String
  /// Cover şəkil URL-i (Cloudinary və ya hər hansı CDN).
  coverImageUrl String?
  /// Optional kategori etiketi: "Yenilik", "Endirim", "Müsahibə", "Bələdçi" və s.
  category      String?
  /// Scope: HOME | PLAYSTATION | STREAMING_OVERVIEW | STREAMING_HBO_MAX | STREAMING_NETFLIX | STREAMING_GAIN | STREAMING_YOUTUBE_PREMIUM
  scope         String    @default("HOME")
  isFeatured    Boolean   @default(false)
  isPublished   Boolean   @default(true)
  /// Ana səhifədə də göstərilirmi — admin paneldən manual seçilir.
  showOnHome    Boolean   @default(false)
  /// Public render üçün effective tarix — null olarsa createdAt istifadə edilir.
  publishedAt   DateTime?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([scope, isPublished, publishedAt])
  @@index([scope, isFeatured, sortOrder])
  @@index([showOnHome, isPublished, publishedAt])
}

// ─── Referral cycles (aylıq leaderboard tracking) ─────────────────────────────
//
// Hər təqvim ayı bir `ReferralCycle` təşkil edir. Cycle daxilində hər referrer
// üçün `ReferralCycleResult` sətri xal yığır:
//   - hər "uğurlu dəvət" üçün +10 xal (referee-nin ilk SUCCESS alışı)
//   - referee-nin xərclədiyi hər AZN üçün +1 xal
// Bonus referal komissiyası kimi məbləğə əsasən verilir (pillə sistemi yoxdur).

model ReferralCycle {
  id        String    @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  closedAt  DateTime?
  createdAt DateTime  @default(now())

  results ReferralCycleResult[]

  @@unique([startsAt])
  @@index([endsAt])
}

model ReferralCycleResult {
  id      String        @id @default(cuid())
  cycleId String
  cycle   ReferralCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  userId  String
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  invites    Int @default(0)
  spendCents Int @default(0)
  points     Int @default(0)

  rank Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cycleId, userId])
  @@index([cycleId, points])
  @@index([userId])
}

// ─── Game reviews (rəylər) + sosial qarşılıqlı təsir + affiliate ──────────────
//
// Hər istifadəçi bir oyun üçün yalnız bir rəy yaza bilər. Rəy admin
// moderasiyasından keçdikdən sonra (status = APPROVED) public görünür.
// Rəy kartındakı "Bu Oyunu Satın Al" düyməsinə klikləyən hər kəs
// `?via=<reviewId>` query parametri ilə oyun səhifəsinə yönləndirilir;
// bu identifikator 30 günlük HTTP-only cookie-yə yazılır və alış SUCCESS
// status alanda rəy müəllifinə referal balansından komissiya yazılır.

model GameReview {
  id     String @id @default(cuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 1..5 (UI-da ulduz). Server tərəfdə də limitlənir.
  rating Int
  // 200..5000 simvol. Hər iki tərəfdə validasiya olunur.
  body   String

  // PENDING | APPROVED | REJECTED | HIDDEN
  // PENDING  — yeni göndərilmiş, admin onayını gözləyir
  // APPROVED — public görünür
  // REJECTED — admin rədd edib (görünməz)
  // HIDDEN   — adminin əvvəl onayladığı, sonra gizlədiyi rəy
  status String @default("PENDING")

  // Admin moderasiya audit-i.
  moderatedAt    DateTime?
  moderatedById  String?
  moderationNote String?

  reactions ReviewReaction[]
  comments  ReviewComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hər istifadəçi bir oyun üçün bir rəy.
  @@unique([userId, gameId])
  @@index([gameId, status, createdAt])
  @@index([userId])
  @@index([status])
}

model ReviewReaction {
  reviewId String
  review   GameReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // +1 (Like) | -1 (Dislike). Toggle: eyni dəyər təkrar gəlsə kayıt silinir,
  // əks dəyər gəlsə isə update olunur.
  value Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([reviewId, userId])
  @@index([reviewId, value])
}

model ReviewComment {
  id       String     @id @default(cuid())
  reviewId String
  review   GameReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  body     String
  // Admin tərəfindən gizlənilibsə, public siyahıda görünmür.
  isHidden Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId, createdAt])
  @@index([userId])
}

// ─── Streaming Scraper: çoklu platform katalog/dil bilgisi ────────────────────

/// Bir StreamingTitle-ın konkret platformdakı mövcudluğu. Eyni başlıq birdən
/// çox platformda yayımlana bilər (məs. eyni film həm Netflix, həm Prime-da).
/// Scraper hər run-da bu cədvəli AZ kataloqu ilə sinxronlaşdırır.
model ContentAvailability {
  id                 String         @id @default(cuid())
  titleId            String
  title              StreamingTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)
  // NETFLIX | HBOMAX | PRIME | GAIN
  platform           String
  // Platform daxilindəki ID/slug — deep link qurmaq üçün (məs. Netflix netflix_id,
  // JustWatch jw_entity_id, Gain üçün URL slug-ı).
  platformExternalId String
  // Region — hazırda hər zaman "AZ", lakin gələcəkdə multi-region üçün saxlanır.
  country            String         @default("AZ")
  // Sonuncu scrape-də platformda görünübsə true. Silindikdə false + removedAt set olunur.
  isAvailable        Boolean        @default(true)
  firstSeenAt        DateTime       @default(now())
  lastSeenAt         DateTime       @default(now())
  removedAt          DateTime?
  // Platform tərəfindəki deep link (məs. https://www.netflix.com/az/title/80100172).
  deepLinkUrl        String?

  languages ContentLanguage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, platformExternalId, country])
  @@index([titleId])
  @@index([platform, isAvailable])
}

/// Bir availability üçün audio/subtitle dil siyahısı. Yalnız tr/ru/en saxlanır —
/// digər dillər scraper-də süzülür (bax `lib/streamingLanguages.ts`).
model ContentLanguage {
  id             String              @id @default(cuid())
  availabilityId String
  availability   ContentAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  // ISO 639-1: "tr" | "ru" | "en"
  code           String
  // AUDIO | SUBTITLE
  kind           String

  createdAt DateTime @default(now())

  @@unique([availabilityId, code, kind])
  @@index([availabilityId])
}

/// Bir scrape run-ında qeyd olunan dəyişiklik (yeni / silinmiş / yenilənmiş).
/// Audit/diff üçün — UI-da "son 24 saatda nə dəyişib" göstərmək üçün istifadə olunur.
model ScrapeChange {
  id          String    @id @default(cuid())
  scrapeRunId String
  scrapeRun   ScrapeRun @relation(fields: [scrapeRunId], references: [id], onDelete: Cascade)
  // NETFLIX | HBOMAX | PRIME | GAIN
  platform    String
  // ADDED | REMOVED | UPDATED
  changeType  String
  // Hələ DB-də olmayan REMOVED case üçün titleId null ola bilər.
  titleId     String?
  // Snapshot — başlıq, platformExternalId və dəyişən sahələr (yeni/köhnə audio/subtitle dilləri).
  payload     Json

  createdAt DateTime @default(now())

  @@index([scrapeRunId])
  @@index([platform, createdAt])
  @@index([titleId])
}

// ─── Admin notes & audit log ──────────────────────────────────────────────────
//
// `AdminNote` — bir istifadəçi haqqında admin tərəfindən yazılan daxili qeyd.
// Müştəri özü görmür; yalnız admin paneldə göstərilir. Telefon zəngi, şikayət,
// manual balans dəyişikliyinin səbəbi və s. üçün istifadə olunur.
//
// `AdminAuditLog` — istifadəçi üzərində aparılan admin əməliyyatlarının audit
// jurnalı (rolünü dəyişdi, balansı redaktə etdi, hesabı blokladı və s.). Hər
// sətir bir əməliyyatın "kim, kimə, nə vaxt, nə etdi" snapshot-udur.

model AdminNote {
  id String @id @default(cuid())

  // Qeydin yazıldığı istifadəçi (müştəri).
  targetUserId String
  targetUser   User   @relation("AdminNoteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  // Qeydi yazan admin. Admin silindikdə qeyd qalır, sadəcə author silinir.
  authorId String?
  author   User?   @relation("AdminNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  body String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetUserId, createdAt])
}

model AdminAuditLog {
  id String @id @default(cuid())

  // Əməliyyatın aparıldığı istifadəçi.
  targetUserId String
  targetUser   User   @relation("AdminAuditTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  // Əməliyyatı aparan admin. Silindikdə audit qalır.
  actorId String?
  actor   User?   @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  // Action key — sərbəst format, məs:
  // "user.role.update" | "user.disable" | "user.enable" | "user.balance.adjust"
  // "user.delete" | "user.password.reset" | "user.email.verify"
  action String

  // İxtiyari detal — JSON snapshot (prev/next dəyərlər, səbəb və s.).
  details String?

  createdAt DateTime @default(now())

  @@index([targetUserId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

// ─── Rate limiting / abuse defence ────────────────────────────────────────────
//
// Hər auth-yönlü cəhd (register, resend-otp, forgot-password) burada qeyd
// olunur. Sürüşən pəncərə (sliding window) ilə son N saniyədəki sətirlər
// sayılaraq limit yoxlanılır. `identifier` ikinci ölçü üçündür — məs: eyni
// IP-dən gələn 5 dəq ərzindəki fərqli telefon nömrələrinin sayını saymaq.
model RateLimitEvent {
  id         String   @id @default(cuid())
  key        String // məs: "register:ip:1.2.3.4" və ya "verify-otp:user:abc"
  scope      String // "register" | "resend-otp" | "forgot-password" | "verify-otp"
  identifier String? // optional ikinci dəyər (phone, email) distinct-count üçün
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([key, createdAt])
  @@index([scope, createdAt])
}

// ─── Website Services (sifarişlə hazırlanan website xidməti) ─────────────────
//
// Bu adi rəqəmsal məhsul kimi alınmır — müştəri ətraflı müraciət formu
// göndərir, admin paneldə baxılır və WhatsApp üzərindən əlaqə saxlanılır.

model WebsiteServicePackage {
  id           String  @id @default(cuid())
  name         String // məs: "Basic Paket", "Standard Paket", "Premium Paket"
  priceRange   String // məs: "150–300 AZN" və ya "600 AZN-dən başlayaraq"
  description  String
  // Xüsusiyyətlər siyahısı — admin panelindən idarə olunan sətirlərin massivi.
  features     Json
  deliveryTime String?
  // "Ən çox seçilən" lentini göstərmək üçün.
  isPopular    Boolean @default(false)
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)

  applications WebsiteServiceApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model WebsiteServiceApplication {
  id String @id @default(cuid())

  // Müştəri məlumatları
  fullName     String
  phone        String
  email        String?
  businessName String?

  // Əlaqə üsulu: "WHATSAPP" | "CALL" | "EMAIL"
  contactMethod String?

  // Layihə tipi: "BUSINESS" | "PORTFOLIO" | "RESTAURANT" | "ECOMMERCE" | "LANDING" | "OTHER"
  websiteType String

  packageId String?
  package   WebsiteServicePackage? @relation(fields: [packageId], references: [id])

  budgetRange String?

  hasLogo    Boolean?
  hasDomain  Boolean?
  hasHosting Boolean?

  projectBrief String

  // Mövcud sayt (yenidən dizayn halında).
  existingWebsiteUrl String?

  // Bəyəndiyi nümunə sayt linkləri (sərbəst mətn — sətir-sətir və ya vergüllə).
  referenceWebsiteLinks String?

  // Logo, brendinq və s. üçün xarici fayl linki (Drive/Dropbox).
  attachmentsUrl String?

  // İstədiyi sayt bölmələri (sətirlərin massivi).
  requestedSections Json?

  // Sayt dilləri (string[] — "AZ" | "EN" | "RU" | "TR").
  languages Json?

  // İstənilən başlama tarixi.
  preferredStartDate DateTime?

  // Layihənin təcililiyi: "NORMAL" | "URGENT" | "FLEXIBLE"
  urgency String?

  wantsCustomDesign Boolean?
  designStyle       String? // "MODERN" | "MINIMAL" | "CORPORATE" | "PLAYFUL" | ...

  // Kontent vəziyyəti: "READY" | "PARTIAL" | "NEED_HELP"
  contentStatus String?

  // Status: "NEW" | "CONTACTED" | "PRICE_GIVEN" | "ACCEPTED" | "REJECTED" | "COMPLETED"
  status String @default("NEW")

  // Admin daxili qeydləri (müştəriyə görünmür).
  adminNotes String?

  // ─── AI ilə hesablanmış qiymət snapshot-u ──────────────────────────────────
  // Müştərinin "Qiymət hesabla" düyməsi ilə aldığı və forma göndərən anda
  // donduğu hesablama. Sonradan admin qiyməti dəyişsə də müraciət öz
  // qiymətini saxlayır.
  estimatedPriceMin Decimal? @db.Decimal(12, 2)
  estimatedPriceMax Decimal? @db.Decimal(12, 2)
  // Seçilmiş add-on-lar — [{ addOnId, slug, name, units, lineTotal, pricingType, ... }].
  selectedAddOns    Json?
  // AI-nın izahı və əmsalı snapshot-u — { reasoning, complexityFactor, baseRange: [min, max] }.
  estimateBreakdown Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

// Admin tərəfindən idarə olunan əlavə xidmətlər (add-on-lar).
// Müştəri formunda canlı görünür, qiymət hesablamasında istifadə olunur.
model WebsiteServiceAddOn {
  id          String  @id @default(cuid())
  slug        String  @unique // məs: "dark-mode", "online-payment"
  name        String           // məs: "Dark / Light mode"
  description String?
  // Qruplaşdırma (UI-da bölmələr üçün): "DESIGN" | "FUNCTIONALITY" | "SETUP" | "OTHER"
  category    String?

  // "FLAT" — sabit qiymət; "PER_UNIT" — N pulsuz + əlavə vahid başına ödəniş.
  pricingType String

  // FLAT üçün.
  flatPrice Decimal? @db.Decimal(10, 2)

  // PER_UNIT üçün (məs. dil dəstəyi: freeUnits=1, unitPrice=20).
  freeUnits Int?
  unitPrice Decimal? @db.Decimal(10, 2)
  unitLabel String? // məs: "dil", "məhsul" — UI üçün

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// Singleton qiymət konfiqurasiyası — AI üçün baza qiymət aralıqları.
// Yalnız bir sətir saxlanılır (id="default").
model WebsitePricingConfig {
  id String @id @default("default")

  // websiteType → { minBase: number, maxBase: number, notes?: string }
  baseRanges Json

  // AI üçün əlavə qaydalar (admin sərbəst yazır — məs. "Ecommerce-də məhsul
  // sayı 100-dən çox olarsa qiyməti ən azı 20% artır").
  aiInstructions String?

  // OpenAI modeli (admin lazım olsa dəyişər).
  aiModel String @default("gpt-4o-mini")

  updatedAt DateTime @updatedAt
}

/// "AI-dan soruş" köməkçisinin bilik bazası — admin paneldən idarə olunur
/// (app/admin/ai-knowledge). Hər sətir bir bilik parçasıdır (başlıq + mətn +
/// kateqoriya). Yalnız `isActive` olanlar chat sistem prompt-una daxil edilir.
/// Cədvəl lib/prisma.ts-dəki ensure-once pattern ilə runtime-da yaradılır.
model AiKnowledge {
  id        String   @id @default(cuid())
  title     String
  content   String
  // GENERAL | PLAYSTATION | STREAMING | GIFT_CARDS | SERVICES | OTHER
  category  String   @default("GENERAL")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

/// "AI-dan soruş" köməkçisində hər müştəri sorğusunun logu — admin paneldə
/// (app/admin/ai-chat-logs) "hansı müştəri nə soruşub" görünüşü üçün. `userId`
/// plain saxlanılır (FK yox); admin tərəf user-ləri ayrıca yığır. Cədvəl
/// lib/prisma.ts-dəki ensure-once pattern ilə runtime-da yaradılır.
model AiChatLog {
  id           String   @id @default(cuid())
  userId       String
  question     String
  reply        String
  productCount Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Honsell İcması (community wall) ──────────────────────────────────────────
//
// "/icma" səhifəsindəki sərbəst topluluq divarı. Üzv istənilən mövzuda qısa
// fikir/post yazır (kateqoriyaya görə süzülür), başqaları like/dislike edə və
// şərh yaza bilər. Oyun rəyləri (GameReview) ilə eyni moderasiya axını:
// PENDING → admin onayı → APPROVED public görünür. Cədvəllər lib/prisma.ts-dəki
// ensure-once pattern ilə runtime-da da yaradılır (Supabase migration olmadan).
model CommunityPost {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // GENERAL | SERIAL | OYUN | ENDIRIM | SUAL — bax lib/community.ts.
  category String @default("GENERAL")
  // Opsional başlıq (qısa). Boş ola bilər.
  title    String?
  // 10..2000 simvol. Hər iki tərəfdə validasiya olunur.
  body     String

  // PENDING | APPROVED | REJECTED | HIDDEN — GameReview ilə eyni semantika.
  status String @default("PENDING")

  // Admin moderasiya audit-i.
  moderatedAt    DateTime?
  moderatedById  String?
  moderationNote String?

  reactions CommunityPostReaction[]
  comments  CommunityPostComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([category, status, createdAt])
  @@index([userId])
}

model CommunityPostReaction {
  postId String
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // +1 (Like) | -1 (Dislike). Toggle: eyni dəyər təkrar gəlsə silinir.
  value Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([postId, userId])
  @@index([postId, value])
}

model CommunityPostComment {
  id     String        @id @default(cuid())
  postId String
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  body     String
  // Admin tərəfindən gizlənilibsə, public siyahıda görünmür.
  isHidden Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([userId])
}
