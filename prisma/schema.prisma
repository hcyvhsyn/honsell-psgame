// Honsell PS Store — Prisma schema
// Provider: PostgreSQL (Supabase).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / Users ─────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  phone          String?
  passwordHash   String
  role           String   @default("USER") // USER | ADMIN

  // Optional profile fields edited from /profile/settings.
  birthDate      DateTime?
  gender         String?    // "MALE" | "FEMALE" | "OTHER"

  emailVerified  Boolean   @default(false)
  otpCode        String?
  otpExpiresAt   DateTime?

  // Wallet (stored in AZN, scaled by 100 to keep integer math clean)
  walletBalance           Int @default(0) // depozit / ödəniş üçün əsas cüzdan

  /** Loyalty cashback bu balansa yığılır (cüzdandan ayrı). */
  cashbackBalanceCents Int @default(0)

  /** Referaldan komissiya ilə düşən balans — ödənişdə ayrıca seçilir. */
  referralBalanceCents Int @default(0)

  // Affiliate / referral
  referralCode   String   @unique
  referredById   String?
  referredBy     User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals      User[]   @relation("Referrals")

  // PSN delivery accounts (one user can have many; one is marked default).
  psnAccounts    PsnAccount[]

  transactions   Transaction[]      @relation("UserTransactions")
  commissions    Transaction[]      @relation("CommissionBeneficiary")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── PSN delivery accounts (one user → many PSN logins) ───────────────────────

model PsnAccount {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Friendly nickname shown in dropdowns ("Main", "Brother", "Eu Region")
  label       String
  psnEmail    String
  psnPassword String   // encrypt at rest in production

  /// Console model the account is bound to. "PS4" | "PS5".
  psModel     String   @default("PS5")

  isDefault   Boolean  @default(false)

  transactions Transaction[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Game {
  id              String   @id @default(cuid())
  // Stable PS Store product id (used to upsert during scraping)
  productId       String   @unique
  title           String
  imageUrl        String?
  productUrl      String?

  // PS4 | PS5 — derived from the productId code (CUSA/PPSA)
  platform        String?

  // GAME | ADDON | CURRENCY | OTHER — derived from storeDisplayClassification
  // GAME      → FULL_GAME, GAME_BUNDLE, PREMIUM_EDITION, null (concept page)
  // ADDON     → ADD_ON_PACK (DLC, costumes, season passes)
  // CURRENCY  → VIRTUAL_CURRENCY (cash cards)
  // OTHER     → themes, avatars, demos, anything else
  productType     String   @default("GAME")

  // Source prices in TRY, scaled by 100 (kuruş). Never shown to users.
  priceTryCents       Int
  discountTryCents    Int?     // null when no discount is active

  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  lastScrapedAt   DateTime @default(now())

  transactions    Transaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([platform])
  @@index([productType])
  @@index([title])
  @@index([isFeatured])
}

// ─── Service Products (TRY Balans, PS Plus, Account Creation) ────────────────

model ServiceProduct {
  id              String   @id @default(cuid())
  // ACCOUNT_CREATION | TRY_BALANCE | PS_PLUS
  type            String
  title           String
  description     String?
  imageUrl        String?
  // Qiymət (AZN qəpiklə)
  priceAznCents   Int

  // Əlavə məlumatlar:
  // TRY_BALANCE üçün: neçə TRY-dir (məs: 250, 500)
  // PS_PLUS üçün: tier (ESSENTIAL/EXTRA/DELUXE) və durationMonths (1, 3, 12)
  metadata        Json?

  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  codes           ServiceCode[]
  transactions    Transaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
}

model ServiceCode {
  id                String   @id @default(cuid())
  serviceProductId  String
  serviceProduct    ServiceProduct @relation(fields: [serviceProductId], references: [id])

  code              String   // 12 rəqəmli e-pin və s.
  isUsed            Boolean  @default(false)

  transactions      Transaction[]

  createdAt         DateTime @default(now())

  @@index([serviceProductId, isUsed])
}

// ─── Transactions (deposits, purchases, commissions) ──────────────────────────

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("UserTransactions", fields: [userId], references: [id])

  // DEPOSIT | PURCHASE | COMMISSION | SERVICE_PURCHASE
  type           String
  // PENDING | SUCCESS | FAILED
  status         String   @default("SUCCESS")

  // Amount in qəpik (AZN * 100). Positive = credit, negative = debit.
  amountAznCents Int

  // Optional purchase details
  gameId         String?
  game           Game?    @relation(fields: [gameId], references: [id])

  serviceProductId String?
  serviceProduct   ServiceProduct? @relation(fields: [serviceProductId], references: [id])

  serviceCodeId  String?
  serviceCode    ServiceCode? @relation(fields: [serviceCodeId], references: [id])

  // Which PSN account this purchase was delivered to. NULL for non-PURCHASE
  // rows (DEPOSIT, COMMISSION) and for legacy data created before multi-PSN.
  psnAccountId   String?
  psnAccount     PsnAccount? @relation(fields: [psnAccountId], references: [id])

  // For COMMISSION rows: the user who earned the commission
  beneficiaryId  String?
  beneficiary    User?    @relation("CommissionBeneficiary", fields: [beneficiaryId], references: [id])

  // Free-form metadata (e.g. masked card, gateway ref)
  metadata       String?

  // Manual-deposit receipt URL (uploaded by the customer, reviewed by admin)
  receiptUrl     String?

  createdAt      DateTime @default(now())

  @@index([status, type])
}

// ─── PS Store scrape history ──────────────────────────────────────────────────

model ScrapeRun {
  id             String    @id @default(cuid())
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  // RUNNING | SUCCESS | FAILED
  status         String    @default("RUNNING")
  // Total unique products extracted from PS Store before persisting.
  scrapedCount   Int       @default(0)
  // Rows actually upserted into Game (== scrapedCount on success).
  upsertedCount  Int       @default(0)
  error          String?

  @@index([startedAt])
}

// ─── Banners (homepage hero carousel) ────────────────────────────────────────

model Banner {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Testimonials (customer reviews on homepage) ──────────────────────────────

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  avatarUrl String?
  text      String
  rating    Int      @default(5)
  // GAME | PS_PLUS | GIFT_CARD | ACCOUNT_CREATION
  platform  String   @default("GAME")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── Global settings (single row, id = "global") ──────────────────────────────

model Settings {
  id                 String   @id @default("global")
  // Multiplier applied to TRY prices. Stored as float for simplicity.
  tryToAznRate       Float    @default(0.053)
  // Profit margin in percent, e.g. 20 means +20%.
  profitMarginPct    Float    @default(20)
  // Legacy: % of purchase price paid to referrer. Kept for back-compat;
  // the active formula is `referralProfitSharePct` below.
  affiliateRatePct   Float    @default(5)
  // % of the store's profit margin shared with the referrer per purchase.
  // Default 20 → at a 20% margin, the referrer effectively gets 4% of revenue.
  referralProfitSharePct Float @default(20)

  // Bank card the customer transfers funds to during manual deposit.
  depositCardNumber  String?
  depositCardHolder  String?

  updatedAt          DateTime @updatedAt
}

// ─── FAQ (homepage "Tez-tez verilən suallar") ─────────────────────────────────

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}
