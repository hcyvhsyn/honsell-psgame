+// ─── Service Products (TRY Balans, PS Plus, Account Creation) ────────────────
+
+model ServiceProduct {
+  id              String   @id @default(cuid())
+  // ACCOUNT_CREATION | TRY_BALANCE | PS_PLUS
+  type            String
+  title           String
+  description     String?
+  // Qiymət (AZN qəpiklə)
+  priceAznCents   Int
+
+  // Əlavə məlumatlar:
+  // TRY_BALANCE üçün: neçə TRY-dir (məs: 250, 500)
+  // PS_PLUS üçün: tier (ESSENTIAL/EXTRA/DELUXE) və durationMonths (1, 3, 12)
+  metadata        Json?    // məs: { "tryAmount": 250 } və ya { "tier": "EXTRA", "durationMonths": 3 }
+
+  isActive        Boolean  @default(true)
+  sortOrder       Int      @default(0)
+  
+  codes           ServiceCode[]
+  transactions    Transaction[]
+
+  createdAt       DateTime @default(now())
+  updatedAt       DateTime @updatedAt
+
+  @@index([type])
+}
+
+model ServiceCode {
+  id                String   @id @default(cuid())
+  serviceProductId  String
+  serviceProduct    ServiceProduct @relation(fields: [serviceProductId], references: [id])
+  
+  code              String   // 12 rəqəmli e-pin və s.
+  isUsed            Boolean  @default(false)
+  
+  transactions      Transaction[]
+  
+  createdAt         DateTime @default(now())
+  
+  @@index([serviceProductId, isUsed])
+}
+
