NEXT_PUBLIC_APP_URL=https://honsell.store
EPOINT_PUBLIC_KEY=
EPOINT_PRIVATE_KEY=

# Website service AI qiymət hesablama (xidmetler/website forumunda istifadə olunur).
# Açar yoxdursa fallback hesablama qaydaları işə düşür — AI çağırılmır.
OPENAI_API_KEY=

# Streaming scrape (Netflix uNoGS / JustWatch / Gain)
# RapidAPI key — uNoGS endpoint-i üçün (Netflix scraper). https://rapidapi.com/unogs/api/unogs
RAPIDAPI_KEY=
# Shared secret — POST /api/scrape üçün Bearer auth. Vercel Cron-da `authorizationHeader` kimi qoyulur.
CRON_SECRET=
# Gain (login arxasında) — DevTools-dan götürülür, 15-30 gün etibarlıdır.
# GAIN_PROFILE_ID: API URL path-ından çıxan uzun string, məs. "J2YHROODFJFHKVY4F0FIXE3E".
# GAIN_COOKIE: Network → Headers → Request Headers → Cookie sətrinin tam dəyəri.
GAIN_PROFILE_ID=
GAIN_COOKIE=

# Epic Games kataloq yığımı (GET /api/admin/scrape-epic)
# Epic-in kataloq GraphQL-i Cloudflare bot-challenge arxasındadır və adi server
# sorğularını bloklayır. Onu keçmək üçün self-hosted FlareSolverr instansı lazımdır:
#   docker run -d --name flaresolverr -p 8191:8191 ghcr.io/flaresolverr/flaresolverr:latest
# FLARESOLVERR_URL qoyulduqda scrape sorğuları onun üzərindən gedir.
FLARESOLVERR_URL=
# İstəyə bağlı: bir sorğu üçün maksimum gözləmə (ms). Default 60000.
FLARESOLVERR_TIMEOUT_MS=
# İstəyə bağlı: GraphQL endpoint-ini əvəz et (məs. başqa proxy). Default store.epicgames.com.
EPIC_GRAPHQL_URL=

